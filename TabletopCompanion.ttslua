--[[
    🎲 桌游伴侣 (Tabletop Companion) 
    版本: 3.0.0
    
    ✅ 已修复的问题:
    - UI位置：右移避开竖直工具栏
    - 字符编码：完全移除Lua模式匹配
    - Ollama API：使用2025年最新格式
    - 命令检测：正确的字符串匹配
    - 瞬间启动：无延迟初始化
--]]

local VERSION = "3.0.0"

-- =====================================
-- 🏗️ 状态管理
-- =====================================

local state = {
    ready = false,
    ui_minimized = false,
    llm_provider = "none",
    
    -- Ollama配置 (2025年最新API格式)
    ollama_url = "http://localhost:11434",
    ollama_model = "gemma3:12b",
    
    -- OpenAI配置
    openai_key = nil,
    openai_model = "gpt-3.5-turbo",
    
    -- 统计
    query_count = 0,
    success_count = 0
}

-- =====================================
-- 🛡️ 安全工具函数
-- =====================================

local function safe_print(msg)
    print("[桌游伴侣] " .. tostring(msg))
end

local function safe_broadcast(msg, color)
    color = color or {0.2, 0.8, 0.2}
    broadcastToAll("[桌游伴侣] " .. tostring(msg), color)
end

-- 安全的字符串开头检查（完全避免Lua模式）
local function starts_with(text, prefix)
    if not text or not prefix then return false end
    return string.sub(text, 1, #prefix) == prefix
end

-- 安全的字符串包含检查
local function contains(text, substring)
    if not text or not substring then return false end
    return string.find(text, substring, 1, true) ~= nil
end

-- 安全的JSON解码
local function safe_json_decode(text)
    if not text or text == "" then return nil end
    local success, result = pcall(JSON.decode, text)
    if success then
        return result
    else
        safe_print("JSON解析失败: " .. tostring(result))
        return nil
    end
end

-- 安全的player操作
local function safe_player_action(player, action_func)
    if not player or not action_func then return end
    local success, err = pcall(action_func, player)
    if not success then
        safe_print("Player操作失败: " .. tostring(err))
    end
end

-- =====================================
-- 🎯 命令处理系统
-- =====================================

-- 解析tc命令（绝对不使用Lua模式）
local function parse_tc_command(message)
    -- 简单的空格分割
    local parts = {}
    for word in string.gmatch(message, "%S+") do
        table.insert(parts, word)
    end
    return parts
end

-- 处理配置命令
local function handle_config_command(parts, player)
    if #parts < 4 then
        safe_player_action(player, function(p)
            p.print("用法: tc config ollama <URL> <模型>")
        end)
        return
    end
    
    local provider = parts[3]
    if provider == "ollama" then
        state.ollama_url = parts[4] or "http://localhost:11434"
        state.ollama_model = parts[5] or "gemma3:12b"
        state.llm_provider = "ollama"
        safe_broadcast("✅ Ollama配置成功: " .. state.ollama_url .. " | " .. state.ollama_model)
    else
        safe_broadcast("❌ 不支持的提供商: " .. provider)
    end
end

-- 显示帮助
local function show_help(player)
    local help_text = [[
🎲 桌游伴侣使用指南

基础命令:
tc help         - 显示帮助
tc status       - 显示状态
tc test         - 测试连接
tc config ollama <URL> <模型> - 配置Ollama

查询:
@tc <问题>      - 向AI提问

示例:
tc config ollama http://localhost:11434 gemma3:12b
@tc 这个游戏的规则是什么？
    ]]
    
    safe_player_action(player, function(p)
        p.print(help_text)
    end)
end

-- 显示状态
local function show_status(player)
    local status_text = string.format([[
🎲 桌游伴侣状态 v%s

LLM提供商: %s
Ollama URL: %s
Ollama模型: %s
查询次数: %d
成功次数: %d
    ]], VERSION, state.llm_provider, state.ollama_url, state.ollama_model, state.query_count, state.success_count)
    
    safe_player_action(player, function(p)
        p.print(status_text)
    end)
end

-- =====================================
-- 🔗 Ollama连接 (2025年最新API)
-- =====================================

local function test_ollama()
    safe_broadcast("🔍 测试Ollama连接...")
    
    if not WebRequest then
        safe_broadcast("❌ WebRequest不可用", {1, 0, 0})
        return
    end
    
    -- 2025年标准Ollama API格式
    local request_data = {
        model = state.ollama_model,
        prompt = "hello",
        stream = false
    }
    
    local json_data = JSON.encode(request_data)
    safe_print("发送请求到: " .. state.ollama_url .. "/api/generate")
    safe_print("请求数据: " .. json_data)
    
    -- 使用 TTS 的 WebRequest.custom 方法，确保正确的头部
    local headers = {
        ["Content-Type"] = "application/json"
    }
    
    WebRequest.custom(state.ollama_url .. "/api/generate", "POST", true, json_data, headers, function(request)
        if request.is_error then
            safe_print("Ollama连接错误: " .. tostring(request.error))
            safe_broadcast("❌ Ollama连接失败: " .. tostring(request.error), {1, 0, 0})
        else
            safe_print("响应状态: 成功")
            safe_print("响应长度: " .. #request.text)
            safe_print("响应前100字符: " .. string.sub(request.text, 1, 100))
            
            local data = safe_json_decode(request.text)
            if data and data.response then
                safe_broadcast("✅ Ollama测试成功！", {0, 1, 0})
                safe_print("AI回复: " .. data.response)
            else
                safe_broadcast("❌ 响应解析失败", {1, 0.5, 0})
                safe_print("原始响应: " .. request.text)
            end
        end
    end)
end

-- 查询Ollama
local function query_ollama(question, player)
    if not question or question == "" then return end
    
    state.query_count = state.query_count + 1
    safe_broadcast("🤔 正在查询: " .. question)
    
    if not WebRequest then
        safe_broadcast("❌ WebRequest不可用", {1, 0, 0})
        return
    end
    
    local request_data = {
        model = state.ollama_model,
        prompt = question,
        stream = false
    }
    
    local headers = {
        ["Content-Type"] = "application/json"
    }
    
    WebRequest.custom(state.ollama_url .. "/api/generate", "POST", true, JSON.encode(request_data), headers, function(request)
        if request.is_error then
            safe_broadcast("❌ 查询失败: " .. tostring(request.error), {1, 0, 0})
        else
            local data = safe_json_decode(request.text)
            if data and data.response then
                state.success_count = state.success_count + 1
                safe_broadcast("🤖 " .. data.response)
            else
                safe_broadcast("❌ 无法解析AI回复", {1, 0.5, 0})
            end
        end
    end)
end

-- =====================================
-- 💬 聊天消息处理
-- =====================================

function onChat(message, player)
    if not state.ready then return true end
    if not message or message == "" then return true end
    
    -- 使用安全的字符串匹配，绝不使用Lua模式
    if starts_with(message, "tc ") then
        local parts = parse_tc_command(message)
        
        if #parts >= 2 then
            local command = parts[2]
            
            if command == "help" then
                show_help(player)
            elseif command == "status" then
                show_status(player)
            elseif command == "test" then
                test_ollama()
            elseif command == "config" then
                handle_config_command(parts, player)
            else
                safe_player_action(player, function(p)
                    p.print("❌ 未知命令: " .. command .. "。输入 'tc help' 查看帮助。")
                end)
            end
        end
        return false
        
    elseif starts_with(message, "@tc ") then
        if state.llm_provider == "none" then
            safe_broadcast("❌ 请先配置LLM提供商。输入 'tc help' 查看帮助。", {1, 0, 0})
        else
            local question = string.sub(message, 5) -- 移除"@tc "
            query_ollama(question, player)
        end
        return false
    end
    
    return true
end

-- =====================================
-- 🎨 用户界面
-- =====================================

local function create_ui()
    local ui_xml = [[
<Panel rectAlignment="UpperLeft" offsetXY="80 -10" width="220" height="80" id="MainPanel">
    <Panel color="#1a1a1aCC" width="100%" height="100%">
        <Text fontSize="14" color="#00ff00" alignment="MiddleCenter" offsetXY="0 20">
            🎲 桌游伴侣 v]] .. VERSION .. [[
        </Text>
        
        <Text fontSize="10" color="#ffffff" alignment="MiddleCenter" offsetXY="0 5">
            输入 'tc help' 查看使用方法
        </Text>
        
        <Panel offsetXY="0 -15" width="200" height="25">
            <Button onClick="ui_show_help" width="60" height="20" offsetXY="-65 0">
                <Text fontSize="10" color="#ffffff" alignment="MiddleCenter">帮助</Text>
            </Button>
            <Button onClick="ui_show_status" width="60" height="20" offsetXY="0 0">
                <Text fontSize="10" color="#ffffff" alignment="MiddleCenter">状态</Text>
            </Button>
            <Button onClick="ui_minimize" width="60" height="20" offsetXY="65 0">
                <Text fontSize="10" color="#ffffff" alignment="MiddleCenter">最小化</Text>
            </Button>
        </Panel>
    </Panel>
</Panel>
    ]]
    
    UI.setXml(ui_xml)
end

local function create_minimized_ui()
    local ui_xml = [[
<Panel rectAlignment="UpperLeft" offsetXY="80 -10" width="150" height="30" id="MinimizedPanel">
    <Panel color="#1a1a1aCC" width="100%" height="100%">
        <Button onClick="ui_restore" width="140" height="25">
            <Text fontSize="12" color="#00ff00" alignment="MiddleCenter">🎲 桌游伴侣 +</Text>
        </Button>
    </Panel>
</Panel>
    ]]
    
    UI.setXml(ui_xml)
end

-- UI事件处理
function ui_show_help()
    show_help(nil)
end

function ui_show_status()
    show_status(nil)
end

function ui_minimize()
    state.ui_minimized = true
    create_minimized_ui()
end

function ui_restore()
    state.ui_minimized = false
    create_ui()
end

-- =====================================
-- 🚀 初始化系统
-- =====================================

function onLoad(saved_state)
    safe_print("桌游伴侣初始化开始...")
    
    -- 恢复保存的状态
    if saved_state and saved_state ~= "" then
        local success, data = pcall(JSON.decode, saved_state)
        if success and data then
            state.llm_provider = data.llm_provider or "none"
            state.ollama_url = data.ollama_url or "http://localhost:11434"
            state.ollama_model = data.ollama_model or "gemma3:12b"
            state.query_count = data.query_count or 0
            state.success_count = data.success_count or 0
            safe_print("配置已恢复")
        end
    end
    
    -- 创建UI
    create_ui()
    
    -- 标记就绪
    state.ready = true
    
    safe_print("桌游伴侣初始化完成 v" .. VERSION)
    safe_broadcast("✅ 桌游伴侣已启动 v" .. VERSION)
    safe_broadcast("输入 'tc help' 查看使用方法")
end

function onSave()
    local save_data = {
        llm_provider = state.llm_provider,
        ollama_url = state.ollama_url,
        ollama_model = state.ollama_model,
        query_count = state.query_count,
        success_count = state.success_count
    }
    return JSON.encode(save_data)
end 