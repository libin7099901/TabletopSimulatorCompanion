-- =====================================
-- 🛡️ 安全工具函数
-- =====================================

local function safe_print(msg)
    print("[桌游伴侣] " .. tostring(msg))
end

local function safe_broadcast(msg, color_for_broadcast, player_target)
    local prefix = "[桌游伴侣] "
    local full_msg = prefix .. tostring(msg)
    
    if player_target and player_target.print then
        local success, err = pcall(player_target.print, full_msg)
        if success then
            safe_print("消息已发送给玩家 " .. tostring(player_target.color or "未知") .. ": " .. full_msg)
        else
            safe_print("向玩家 " .. tostring(player_target.color or "未知") .. " 发送消息失败: " .. tostring(err) .. " - 消息: " .. full_msg)
        end
    elseif broadcastToAll then
        local bc_color = color_for_broadcast or {0.2, 0.8, 0.2}
        local success, err = pcall(broadcastToAll, full_msg, bc_color)
        if not success then
            safe_print("全局广播失败: " .. tostring(err) .. " - " .. full_msg)
        end
    else
        safe_print("broadcastToAll/player.print 不可用 - " .. full_msg)
    end
end

-- 安全的字符串开头检查（完全避免Lua模式）
local function starts_with(text, prefix)
    if not text or not prefix then return false end
    if #text < #prefix then return false end
    
    for i = 1, #prefix do
        if text:sub(i, i) ~= prefix:sub(i, i) then
            return false
        end
    end
    return true
end

-- 安全的字符串包含检查
local function contains(text, substring)
    if not text or not substring then return false end
    if #substring > #text then return false end
    
    for i = 1, #text - #substring + 1 do
        local match = true
        for j = 1, #substring do
            if text:sub(i + j - 1, i + j - 1) ~= substring:sub(j, j) then
                match = false
                break
            end
        end
        if match then
            return true
        end
    end
    return false
end

-- 辅助函数：手动修剪字符串两端的空格和制表符
local function manual_trim(text)
    if not text or type(text) ~= "string" then return "" end
    local s = 1
    local e = #text
    while s <= e and (text:sub(s,s) == " " or text:sub(s,s) == "\t") do
        s = s + 1
    end
    while e >= s and (text:sub(e,e) == " " or text:sub(e,e) == "\t") do
        e = e - 1
    end
    if s > e then return "" else return text:sub(s, e) end
end

-- 辅助函数：手动替换所有出现的子字符串 (区分大小写, 字面量查找)
local function manual_replace_all_literal(text, find_literal, replace_with)
    if not text or type(text) ~= "string" then return text end
    if not find_literal or type(find_literal) ~= "string" or find_literal == "" then return text end 
    if replace_with == nil or type(replace_with) ~= "string" then replace_with = "" end

    local result = ""
    local current_pos = 1
    local find_len = #find_literal

    while true do
        local start_match = string.find(text, find_literal, current_pos, true) -- true for plain literal match
        if start_match then
            result = result .. text:sub(current_pos, start_match - 1) .. replace_with
            current_pos = start_match + find_len
        else
            result = result .. text:sub(current_pos)
            break
        end
    end
    return result
end

-- 安全的JSON编码
local function safe_json_encode(data)
    if not JSON then
        safe_print("JSON模块不可用，使用简单编码")
        return "JSON_NOT_AVAILABLE"
    end
    
    local success, result = pcall(JSON.encode, data)
    if success then
        return result
    else
        safe_print("JSON编码失败: " .. tostring(result))
        return nil
    end
end

-- 安全的JSON解码
local function safe_json_decode(text)
    if not text or text == "" then return nil end
    if not JSON then
        safe_print("JSON模块不可用，无法解码")
        return nil
    end
    
    local success, result = pcall(JSON.decode, text)
    if success then
        return result
    else
        safe_print("JSON解析失败: " .. tostring(result))
        return nil
    end
end

-- 安全的player操作
local function safe_player_action(player, action_func, action_name_for_log)
    local log_action_name = action_name_for_log or "未知操作"
    if not player then
        safe_print(string.format("safe_player_action: 'player' 参数为 nil (类型: %s)，无法执行操作 '%s'。", type(player), log_action_name))
        -- 也许向全局广播一个更通用的错误，因为我们没有目标玩家
        safe_broadcast(string.format("错误：尝试对无效玩家执行操作 '%s'。", log_action_name), "Red")
        return
    end
    if type(action_func) ~= "function" then
        safe_print(string.format("safe_player_action: 'action_func' 参数不是一个函数 (类型: %s)，无法执行操作 '%s' (玩家: %s)。", type(action_func), log_action_name, player.color or "未知"))
        safe_broadcast(string.format("错误：操作 '%s' 的内部配置不正确。", log_action_name), "Red", player) -- 定向给玩家
        return
    end

    -- 确保 player.print 存在 (如果 action_func 依赖它)
    -- 您的 action_func (匿名函数 function(p) p.print(text) end) 确实依赖 player.print
    if not player.print then
        safe_print(string.format("safe_player_action: 'player.print' 不存在于提供的 player 对象中 (玩家: %s)，无法执行操作 '%s'。", player.color or "未知", log_action_name))
        safe_broadcast(string.format("错误：无法向玩家 '%s' 显示消息 (操作: %s)。", player.color or "未知", log_action_name), "Orange", player)
        return
    end
    
    safe_print(string.format("safe_player_action: 准备为玩家 %s 执行操作 '%s'。", player.color or "未知", log_action_name))
    local success, err = pcall(action_func, player)
    if not success then
        safe_print(string.format("safe_player_action: 执行操作 '%s' 时发生错误 for player %s: %s", log_action_name, player.color or "未知", tostring(err)))
        -- 避免在错误处理中再次调用 player.print，以防它就是问题所在
        safe_broadcast(string.format("执行操作 '%s' 时出错: %s", log_action_name, tostring(err)), "Red") -- 全局广播错误
    end
end

-- Helper to safely get a property or call a method on a TTS Object
local function get_obj_prop(obj, prop_name, is_method, default_val, ...)
    if not obj then 
        return default_val 
    end
    
    local obj_type_str = type(obj)
    if obj_type_str ~= 'userdata' and obj_type_str ~= 'table' then
        return default_val 
    end

    local property_value_raw
    local prop_access_success, prop_access_error = pcall(function() property_value_raw = obj[prop_name] end)

    if not prop_access_success then
        -- This means accessing obj[prop_name] itself (the field/method name) caused an error.
        -- Example: Trying to access a field on a LuaGameObjectScript that truly doesn't exist at C++ level.
        -- safe_print(string.format("get_obj_prop: Error accessing property/method '%s' on object %s (type: %s). Pcall Error: %s", prop_name, tostring(obj), obj_type_str, tostring(prop_access_error)))
        return default_val
    end
    
    local property_type_str = type(property_value_raw)

    if is_method then
        if property_type_str == 'function' then
            local call_success, call_result = pcall(property_value_raw, obj, ...) 
            if call_success then
                return call_result
            else
                -- safe_print(string.format("get_obj_prop: Method call '%s' on object %s (type: %s) failed. Call Error: %s", prop_name, tostring(obj), obj_type_str, tostring(call_result)))
                return default_val
            end
        else
            -- safe_print(string.format("get_obj_prop: Property '%s' on object %s (type: %s) is not a function (it is '%s'). Cannot call as method.", prop_name, tostring(obj), obj_type_str, property_type_str))
            return default_val
        end
    else -- direct property access (already retrieved as property_value_raw)
        return property_value_raw 
    end
end

-- 辅助函数：解析 "X Y" 格式的 offsetXY 字符串为数字
local function parse_offset_xy_string(offset_str)
    if not offset_str or type(offset_str) ~= "string" then return 80, -10 end -- Default if invalid
    local x_str, y_str = offset_str:match("([%-?%d%.]+)%s+([%-?%d%.]+)")
    local x = tonumber(x_str) or 80
    local y = tonumber(y_str) or -10
    return x, y
end

-- =====================================
-- 🎮 游戏上下文收集系统 (API Informed Refactor)
-- =====================================

-- 尝试自动检测游戏名称 (MOVED BEFORE gather_game_info)
local function detect_game_name()
    local potential_game_names = {}
    if not getObjects or type(getObjects) ~= 'function' then -- API Check
        safe_print("detect_game_name: getObjects API is not available or not a function. Type: " .. type(getObjects))
        return state.current_game_name or "未知游戏"
    end

    local success_go, all_objects = pcall(getObjects)
    if not success_go or not all_objects then 
        safe_print("detect_game_name: Call to getObjects failed or returned nil. Error: " .. tostring(all_objects))
        return state.current_game_name or "未知游戏" 
    end
    if type(all_objects) ~= 'table' then
        safe_print("detect_game_name: getObjects did not return a table (type: " .. type(all_objects) .. "). Cannot iterate.")
        return state.current_game_name or "未知游戏"
    end
    safe_print(string.format("detect_game_name: Found %d objects to analyze.", #all_objects))

    local game_title_keywords = {"rulebook", "rules", "manual", "instructions", "game board", "gameboard", "board", "playmat"}
    local game_title_tags = {"rulebook", "game board", "rules"}

    -- 内部辅助函数，用于安全地执行gsub
    local function safe_gsub(text_input, pattern, replacement)
        if not text_input or text_input == "" then return text_input or "" end
        if type(text_input) ~= "string" then 
            safe_print(string.format("detect_game_name/safe_gsub: input is not a string (type: %s), pattern: %s. Input: '%s'", type(text_input), pattern, tostring(text_input)))
            return text_input
        end
        local success, result = pcall(string.gsub, text_input, pattern, replacement)
        if success then
            return result
        else
            safe_print(string.format("detect_game_name: string.gsub 调用失败 (模式: '%s')。错误: %s. Input: '%s'", pattern, tostring(result), text_input))
            return text_input -- 返回原始文本
        end
    end

    -- Priority 1:
    for _, obj_instance in ipairs(all_objects) do
        local name_lower = get_obj_prop(obj_instance, "getName", true, "")
        if name_lower and name_lower ~= "" and type(name_lower) == "string" then name_lower = string.lower(name_lower) else name_lower = "" end
        
        local tags_tbl = get_obj_prop(obj_instance, "getTags", true, {})
        local is_priority_object = false

        for _, keyword in ipairs(game_title_keywords) do
            if contains(name_lower, keyword) then is_priority_object = true; break; end
        end
        if not is_priority_object then
            for _, tag_str in ipairs(tags_tbl) do
                local tag_str_lower = tag_str
                if tag_str_lower and tag_str_lower ~= "" and type(tag_str_lower) == "string" then tag_str_lower = string.lower(tag_str_lower) else tag_str_lower = "" end
                for _, keyword_tag in ipairs(game_title_tags) do
                    if tag_str_lower == keyword_tag then is_priority_object = true; break; end
                end
                if is_priority_object then break; end
            end
        end

        if is_priority_object then
            local original_name = get_obj_prop(obj_instance, "getName", true, "")
            local cleaned_name = original_name

            if cleaned_name and type(cleaned_name) == "string" then
                cleaned_name = safe_gsub(cleaned_name, "%s*%([%w%s_.:/%-%?!]+%)$", "")
                cleaned_name = safe_gsub(cleaned_name, "%s*%[[%w%s_.:/%-%?!]+%]]$", "") -- TTS uses ]] for end of block comments in some contexts, ensure this is OK
                cleaned_name = safe_gsub(cleaned_name, "(?i)[-%s]*(rulebook|rules|manual|instructions|scripted|official|edition|game board|gameboard|game|book|playmat)[-%s]*", " ")
                cleaned_name = safe_gsub(cleaned_name, "(?i)rules for", "")
                cleaned_name = safe_gsub(cleaned_name, "^[Tt]he%s+", "") 
                cleaned_name = safe_gsub(cleaned_name, "(?i)[Tt]abletop [Ss]imulator%s*[Mm]od", "")
                cleaned_name = safe_gsub(cleaned_name, "(?i)[Bb]y%s+[%w%s]+$", "") 
                cleaned_name = safe_gsub(cleaned_name, "(?i)[Vv]%d+[%.%d_]*", "") 
                cleaned_name = safe_gsub(cleaned_name, "[_%-%.:/%?!]+|'(s)", " ")
                cleaned_name = manual_replace_all_literal(cleaned_name, "&amp;", "and")
                cleaned_name = safe_gsub(cleaned_name, "%s%s+", " ")
                cleaned_name = manual_trim(cleaned_name)
            else
                cleaned_name = "" 
            end
            
            if cleaned_name ~= "" and #cleaned_name > 2 and #cleaned_name < 70 then
                local unique = true
                for _,p_name_obj in ipairs(potential_game_names) do if p_name_obj.name == cleaned_name then unique=false; break; end end
                if unique then table.insert(potential_game_names, {name = cleaned_name, priority = 1, len = #cleaned_name}) end
            end
        end
    end

    -- Priority 2:
    if #potential_game_names == 0 then
        safe_print("detect_game_name: No priority 1 names found. Starting priority 2 scan.")
        for i, obj_instance in ipairs(all_objects) do
            local original_name = get_obj_prop(obj_instance, "getName", true, "")
            local nickname = get_obj_prop(obj_instance, "getNickname", true, "")
            local obj_type = get_obj_prop(obj_instance, "type", false, "Unknown")
            local scale_vec = get_obj_prop(obj_instance, "getScale", true, {x=1,y=1,z=1})
            local current_name_to_check = original_name
            if current_name_to_check == "" and nickname ~= "" then current_name_to_check = nickname end
            local name_lower = string.lower(current_name_to_check or "")

            if i <= 10 or (#name_lower > 5 and #name_lower < 70) then -- Log first few, and then only potential candidates
                safe_print(string.format("detect_game_name (P2 Scan, Obj %d): Name: '%s', Nick: '%s', Type: %s, Scale: %s, %s, %s. Effective Lower: '%s'", 
                    i, tostring(original_name), tostring(nickname), tostring(obj_type), 
                    tostring(scale_vec.x), tostring(scale_vec.y), tostring(scale_vec.z), name_lower))
            end

            local is_large_custom = false
            if obj_type and type(obj_type) == "string" then
                is_large_custom = (string.sub(obj_type, 1, 7) == "Custom_" and (scale_vec.x > 2 or scale_vec.y > 2 or scale_vec.z > 2))
            end

            if #name_lower > 5 and #name_lower < 70 and (is_large_custom or not (contains(name_lower, "zone") or contains(name_lower, "button") or contains(name_lower, "dice") or contains(name_lower, "card") or contains(name_lower, "token") or contains(name_lower, "marker") or contains(name_lower, "bag") or contains(name_lower, "deck") or contains(name_lower, "mat") or contains(name_lower, "tray") or contains(name_lower, "holder"))) then
                local cleaned_name = original_name
                if cleaned_name and type(cleaned_name) == "string" then
                    cleaned_name = safe_gsub(cleaned_name, "%s*%([%w%s_.:/%-%?!]+%)$", "") 
                    cleaned_name = safe_gsub(cleaned_name, "(?i)[-%s]*(scripted|official)[-%s]*", " ")
                    cleaned_name = safe_gsub(cleaned_name, "[_%-%.:/%?!]+|'(s)", " ") 
                    cleaned_name = manual_replace_all_literal(cleaned_name, "&amp;", "and")
                    cleaned_name = safe_gsub(cleaned_name, "%s%s+", " ") 
                    cleaned_name = manual_trim(cleaned_name)
                else
                    cleaned_name = ""
                end
                if cleaned_name ~= "" and #cleaned_name > 3 then
                    local unique = true
                    for _,p_name_obj in ipairs(potential_game_names) do if p_name_obj.name == cleaned_name then unique=false; break; end end
                    if unique then table.insert(potential_game_names, {name = cleaned_name, priority = 2, len = #cleaned_name}) end
                end
            end
        end
    end
    
    -- Priority 3: Game Save Name
    if #potential_game_names == 0 then
        safe_print("detect_game_name: No priority 1 or 2 names found. Checking game save name (Info.game_name).")
        local game_save_name = ""
        if Info and type(Info) == 'userdata' then -- CORRECTED: Info should be userdata
            game_save_name = get_obj_prop(Info, "game_name", false, "")
            safe_print("detect_game_name (P3): Info.game_name raw value: '" .. tostring(game_save_name) .. "'")
        else
            safe_print("detect_game_name (P3): Info global is not available or not userdata. Type: " .. type(Info))
        end
        
        if game_save_name and game_save_name ~= "" then
            local cleaned_name = game_save_name
            if cleaned_name and type(cleaned_name) == "string" then
                cleaned_name = safe_gsub(cleaned_name, "%s*%([%w%s_.:/%-%?!]+%)$", "")
                cleaned_name = safe_gsub(cleaned_name, "[_%-%.:/%-%?!]+|'(s)", " ") 
                cleaned_name = manual_replace_all_literal(cleaned_name, "&amp;", "and")
                cleaned_name = safe_gsub(cleaned_name, "%s%s+", " ") 
                cleaned_name = manual_trim(cleaned_name)
            else
                cleaned_name = ""
            end
            if cleaned_name ~= "" and #cleaned_name > 2 then
                table.insert(potential_game_names, {name = cleaned_name, priority = 3, len = #cleaned_name})
            end
        end
    end

    local final_name_to_return
    if #potential_game_names > 0 then
        table.sort(potential_game_names, function(a,b) 
            if a.priority ~= b.priority then return a.priority < b.priority end
            return a.len > b.len
        end)
        if potential_game_names[1].name and potential_game_names[1].name ~= "" then 
            final_name_to_return = potential_game_names[1].name 
        end
    end

    if not final_name_to_return then
      final_name_to_return = state.current_game_name or "未知游戏"
    end
    
    if final_name_to_return == "未知游?" then 
        safe_print("detect_game_name: Correcting '未知游?' to '未知游戏'")
        final_name_to_return = "未知游戏"
    end

    safe_print(string.format("detect_game_name: Determined game name: '%s' (length: %d)", tostring(final_name_to_return), (final_name_to_return and type(final_name_to_return) == 'string' and #final_name_to_return or 0)))
    return final_name_to_return
end

local function gather_game_info()
    local game_info = {
        timestamp = os.time(),
        game_name = state.current_game_name or "未知游戏", 
        player_count = 0,
        seated_players_colors = {},
        turn_info = {
            current_player_color = "N/A",
            turn_order = {},
            round = nil, -- Optional, may not exist in all games
            phase = nil  -- Optional, may not exist in all games
        },
        game_mode = nil -- e.g., "Standard", "Hotseat"
    }

    -- Try to detect/update game name
    safe_print("gather_game_info: Attempting to detect game name. Current state.current_game_name: '" .. tostring(state.current_game_name) .. "'")
    local gn_success, detected_name_val = pcall(detect_game_name)
    if gn_success and detected_name_val and type(detected_name_val) == 'string' and detected_name_val ~= "" and detected_name_val ~= "未知游戏" then
        if state.current_game_name ~= detected_name_val then
            safe_print("gather_game_info: Game name CHANGED from '" .. state.current_game_name .. "' to '" .. detected_name_val .. "'")
            state.current_game_name = detected_name_val
        else
             safe_print("gather_game_info: Detected game name '" .. detected_name_val .. "' matches current state.current_game_name.")
        end
        game_info.game_name = detected_name_val
    elseif not gn_success then
        safe_print("gather_game_info: detect_game_name call failed. Error: " .. tostring(detected_name_val)) 
    else
        safe_print("gather_game_info: detect_game_name did not return a new valid name (returned: '" .. tostring(detected_name_val) .. "', type: "..type(detected_name_val).."). Using current: '"..tostring(game_info.game_name).."'")
    end

    if getSeatedPlayers and type(getSeatedPlayers) == 'function' then -- API Check
        local success_sp, seated_player_colors_tbl = pcall(getSeatedPlayers)
        if success_sp and seated_player_colors_tbl and type(seated_player_colors_tbl) == 'table' then
            game_info.seated_players_colors = seated_player_colors_tbl
            game_info.player_count = #seated_player_colors_tbl
            safe_print("gather_game_info: Found " .. game_info.player_count .. " seated players.")
        else 
            safe_print("gather_game_info: Call to getSeatedPlayers failed or returned invalid data. Error/Data: " .. tostring(seated_player_colors_tbl))
        end
    else 
        safe_print("gather_game_info: getSeatedPlayers API is not available or not a function. Type: " .. type(getSeatedPlayers)) 
    end

    if Turn and type(Turn) == 'table' then -- API Check for Turn table
        game_info.turn_info.current_player_color = get_obj_prop(Turn, "getTurnColor", true, "N/A")
        game_info.turn_info.turn_order = get_obj_prop(Turn, "getTurnOrder", true, {})
        game_info.turn_info.round = get_obj_prop(Turn, "getRound", true, nil) -- May return nil
        game_info.turn_info.phase = get_obj_prop(Turn, "getPhase", true, nil) -- May return nil
    else
        safe_print("gather_game_info: Turn API is not available or not a table. Type: " .. type(Turn))
    end
    
    if Info and type(Info) == 'userdata' then -- CORRECTED: Info should be userdata
        game_info.game_mode = get_obj_prop(Info, "GameMode", false, nil) 
    else
        safe_print("gather_game_info: Info API is not available or not userdata. Type: " .. type(Info))
    end

    return game_info
end

local function gather_objects_info()
    if not state.include_objects then return {} end

    local objects_summary = {
        total_objects = 0,
        by_type = {},
        cards = {}, dice = {}, tokens = {}, figures = {}, boards = {}, decks = {}, bags = {}, 
        custom_models = {}, custom_tokens = {}, custom_tiles = {}, custom_cards = {},
        custom_dice = {}, custom_figurines = {}, custom_assetbundles = {},
        other = {}
    }

    if not getObjects then 
        safe_print("getObjects函数不可用 (gather_objects_info)")
        return objects_summary 
    end
    
    local success_go, all_objects_array = pcall(getObjects)
    if not success_go or not all_objects_array then
        safe_print("获取对象列表失败 (gather_objects_info): " .. tostring(all_objects_array))
        return objects_summary
    end

    objects_summary.total_objects = #all_objects_array
    for _, obj_instance in ipairs(all_objects_array) do
        local data = {}
        local quantity

        if not obj_instance or type(obj_instance) ~= 'userdata' then 
            objects_summary.total_objects = objects_summary.total_objects - 1 
            goto continue_object_loop -- Lua goto needs a label
        end

        data.guid = get_obj_prop(obj_instance, "getGUID", true, "N/A-"..tostring(math.random(1,10000)))
        data.name = get_obj_prop(obj_instance, "getName", true, "")
        data.nickname = get_obj_prop(obj_instance, "getNickname", true, "")
        data.description = get_obj_prop(obj_instance, "getDescription", true, "")
        data.type = get_obj_prop(obj_instance, "type", false, "Unknown") -- Object.type is a property
        data.tags = get_obj_prop(obj_instance, "getTags", true, {})
        data.locked = get_obj_prop(obj_instance, "getLock", true, false)
        data.gm_notes = get_obj_prop(obj_instance, "getGMNotes", true, "")
        data.memo = get_obj_prop(obj_instance, "getMemo", true, nil) -- Object.getMemo()
        data.script_id = get_obj_prop(obj_instance, "getVar", true, nil, "script_id") -- Object.getVar("script_id")
        data.position = get_obj_prop(obj_instance, "getPosition", true, {x=0,y=0,z=0})
        -- data.rotation = get_obj_prop(obj_instance, "getRotation", true, {x=0,y=0,z=0}) -- Can be verbose
        -- data.scale = get_obj_prop(obj_instance, "getScale", true, {x=1,y=1,z=1}) -- Can be verbose

        if not objects_summary.by_type[data.type] then objects_summary.by_type[data.type] = 0 end
        objects_summary.by_type[data.type] = objects_summary.by_type[data.type] + 1

        if data.type == "Card" or data.type == "Custom_Card" then
            data.is_face_up = get_obj_prop(obj_instance, "isFaceUp", true, nil)
            data.card_id = get_obj_prop(obj_instance, "getCardID", true, nil) -- Object.getCardID()
            local card_details_success, card_def = pcall(function() return obj_instance.getCardDetails() end) 
            if card_details_success and card_def then data.card_details = card_def end 
            if data.type == "Card" then table.insert(objects_summary.cards, data) else table.insert(objects_summary.custom_cards, data) end
        elseif data.type == "Deck" or (data.type == "Infinite" and (contains(data.name:lower(), "deck") or contains(data.nickname:lower(),"deck"))) then
            data.count = get_obj_prop(obj_instance, "getQuantity", true, 0) -- For Decks (number of cards), Infinite (value in XML if stack)
            local contained_objs_data = get_obj_prop(obj_instance, "getObjects", true, nil) -- For Decks/Bags to list contents
            if contained_objs_data then 
                data.contained_guids = {}
                for _,c_obj in ipairs(contained_objs_data) do
                    table.insert(data.contained_guids, get_obj_prop(c_obj, "guid", false, "INVALID_GUID"))
                end
                data.contained_count = #contained_objs_data
            end
            table.insert(objects_summary.decks, data)
        elseif data.type == "Bag" or (data.type == "Infinite" and (contains(data.name:lower(),"bag") or contains(data.nickname:lower(),"bag"))) then
            data.contained_count = 0
            local contained_objs_data = get_obj_prop(obj_instance, "getObjects", true, nil) -- For Bags to list contents
            if contained_objs_data then 
                data.contained_guids = {}
                 for _,c_obj in ipairs(contained_objs_data) do
                    table.insert(data.contained_guids, get_obj_prop(c_obj, "guid", false, "INVALID_GUID"))
                end
                data.contained_count = #contained_objs_data
            end
            table.insert(objects_summary.bags, data)
        elseif data.type == "Dice" or data.type == "Custom_Dice" then
            data.value = get_obj_prop(obj_instance, "getRotationValue", true, 0)
            -- data.values = get_obj_prop(obj_instance, "getRotationValues", true, nil) -- Can be verbose for complex dice
            if data.type == "Dice" then table.insert(objects_summary.dice, data) else table.insert(objects_summary.custom_dice, data) end
        elseif data.type == "Counter" or data.type == "Chip" then
            data.value = get_obj_prop(obj_instance, "getValue", true, nil)
            table.insert(objects_summary.tokens, data) -- Treat as token
        elseif data.type == "Figurine" then table.insert(objects_summary.figures, data)
        elseif data.type == "Custom_Figurine" then table.insert(objects_summary.custom_figurines, data)
        elseif data.type == "GameBoard" then table.insert(objects_summary.boards, data)
        elseif data.type == "Custom_Token" then 
            data.value = get_obj_prop(obj_instance, "getValue", true, nil) -- Often custom tokens also use this
            table.insert(objects_summary.custom_tokens, data)
        elseif data.type == "Custom_Model" then table.insert(objects_summary.custom_models, data)
        elseif data.type == "Custom_Tile" then table.insert(objects_summary.custom_tiles, data)
        elseif data.type == "Custom_Assetbundle" then table.insert(objects_summary.custom_assetbundles, data)
        else 
            -- Generic token/marker check based on name for items not fitting above types
            if contains(data.name:lower(), "token") or contains(data.nickname:lower(), "token") or 
               contains(data.name:lower(), "marker") or contains(data.nickname:lower(), "marker") or
               contains(data.name:lower(), "counter") or contains(data.nickname:lower(), "counter") then
                table.insert(objects_summary.tokens, data)
            else
                table.insert(objects_summary.other, data)
            end
        end
        
        quantity = get_obj_prop(obj_instance, "getQuantity", true, 0) -- For stackable items
        if quantity > 1 then data.quantity_in_stack = quantity end 

        if string.sub(data.type, 1, 7) == "Custom_" then
            local custom_obj_data = get_obj_prop(obj_instance, "getCustomObject", true, nil)
            if custom_obj_data then 
                data.custom_data = {}
                if custom_obj_data.image then data.custom_data.image_url = custom_obj_data.image end
                if custom_obj_data.mesh then data.custom_data.mesh_url = custom_obj_data.mesh end
                if custom_obj_data.type then data.custom_data.custom_type_id = custom_obj_data.type end -- e.g. CustomToken, CustomCard etc.
            end
        end
        
        ::continue_object_loop::
    end
    return objects_summary
end

local function gather_players_info()
    if not state.include_players then return {} end
    local players_map = {}
    if not getSeatedPlayers or type(getSeatedPlayers) ~= 'function' then -- API Check
        safe_print("gather_players_info: getSeatedPlayers API is not available or not a function. Type: " .. type(getSeatedPlayers))
        return players_map 
    end

    local success_sp, seated_colors_tbl = pcall(getSeatedPlayers)
    if not success_sp or not seated_colors_tbl or type(seated_colors_tbl) ~= 'table' then
        safe_print("gather_players_info: Call to getSeatedPlayers failed or returned invalid data. Error/Data: " .. tostring(seated_colors_tbl))
        return players_map
    end
    safe_print(string.format("gather_players_info: getSeatedPlayers returned %d color strings.", #seated_colors_tbl))

    for i, color_string in ipairs(seated_colors_tbl) do
        safe_print(string.format("gather_players_info: Processing player %d, color_string: '%s' (type: %s)", i, tostring(color_string), type(color_string)))
        
        if color_string and type(color_string) == 'string' then
            local player_entry_exists = Player and Player[color_string]
            local player_entry_type = type(player_entry_exists) 
            safe_print(string.format("gather_players_info: Checking Player['%s']. Exists? %s. Type: %s", color_string, tostring(player_entry_exists ~= nil), player_entry_type))

            if player_entry_exists and player_entry_type == 'userdata' then
                local p_instance = Player[color_string] 
                
                safe_print(string.format("gather_players_info: Player['%s'] is userdata. Steam Name: '%s'", 
                                    color_string, tostring(get_obj_prop(p_instance, "steam_name", false, "N/A"))))

                local p_data = {
                    color = color_string,
                    steam_name = get_obj_prop(p_instance, "steam_name", false, "N/A"),
                    team = get_obj_prop(p_instance, "team", false, "N/A"),
                    promoted = get_obj_prop(p_instance, "promoted", false, false),
                    blindfolded = get_obj_prop(p_instance, "getBlindfolded", true, false),
                    host = get_obj_prop(p_instance, "host", false, false),
                    ping = get_obj_prop(p_instance, "ping", false, 0),
                    hand_zone_info = { object_guids = {}, object_count = 0 },
                    held_object_info = { guid = nil, name = nil, type = nil },
                    selected_objects_count = 0
                }

                local hand_objs_array = get_obj_prop(p_instance, "getHandObjects", true, nil)
                if hand_objs_array then 
                    p_data.hand_zone_info.object_count = #hand_objs_array
                    for _, h_obj in ipairs(hand_objs_array) do
                        table.insert(p_data.hand_zone_info.object_guids, get_obj_prop(h_obj, "guid", false, "INVALID_GUID"))
                    end
                end

                local held_obj_array = get_obj_prop(p_instance, "getHoldingObjects", true, nil)
                if held_obj_array and #held_obj_array > 0 then
                    local primary_held_obj = held_obj_array[1] 
                    p_data.held_object_info.guid = get_obj_prop(primary_held_obj, "guid", false, "N/A")
                    p_data.held_object_info.name = get_obj_prop(primary_held_obj, "getName", true, "N/A")
                    p_data.held_object_info.type = get_obj_prop(primary_held_obj, "type", false, "N/A")
                end
                
                local selected_objs_array = get_obj_prop(p_instance, "getSelectedObjects", true, nil)
                if selected_objs_array then p_data.selected_objects_count = #selected_objs_array end
                
                players_map[color_string] = p_data
            else
                safe_print(string.format("gather_players_info: Player['%s'] instance not found, is nil, or not userdata (type: %s). Skipping data population.", tostring(color_string), player_entry_type))
            end
        else 
            safe_print(string.format("gather_players_info: Invalid color_string at index %d ('%s', type: %s). Skipping player processing.", i, tostring(color_string), type(color_string)))
        end
        -- ::continue_player_loop:: -- Label is no longer needed
    end
    return players_map
end

local function gather_zones_info()
    if not state.include_zones then return {} end
    local zones_data = { scripting_zones = {}, layout_zones = {}, other_zones = {} }
    if not getZones or type(getZones) ~= 'function' then -- API Check
        safe_print("gather_zones_info: getZones API is not available or not a function. Type: " .. type(getZones))
        return zones_data 
    end

    local success_gz, zones_list_array = pcall(getZones)
    if not success_gz or not zones_list_array or type(zones_list_array) ~= 'table' then
        safe_print("gather_zones_info: Call to getZones failed or returned invalid data. Error/Data: " .. tostring(zones_list_array))
        return zones_data
    end
    safe_print(string.format("gather_zones_info: Found %d zones.", #zones_list_array))

    for _, zone_instance in ipairs(zones_list_array) do
        if zone_instance and type(zone_instance) == 'userdata' then
            local z_data = {
                guid = get_obj_prop(zone_instance, "getGUID", true, "N/A-"..tostring(math.random(1,10000))),
                type = get_obj_prop(zone_instance, "type", false, "Unknown"), 
                script_id = get_obj_prop(zone_instance, "getVar", true, nil, "script_id"),
                memo = get_obj_prop(zone_instance, "getMemo", true, nil),
                contained_objects_count = 0,
                contained_object_guids = {}
                -- transform details (position, rotation, scale, bounds) can be verbose
                -- scale = get_obj_prop(zone_instance, "getScale", true, {x=1,y=1,z=1}), 
                -- bounds = get_obj_prop(zone_instance, "getBounds", true, nil) 
            }
            local contained_in_zone_array = get_obj_prop(zone_instance, "getObjects", true, nil)
            if contained_in_zone_array then 
                z_data.contained_objects_count = #contained_in_zone_array
                for _, c_obj in ipairs(contained_in_zone_array) do
                    table.insert(z_data.contained_object_guids, get_obj_prop(c_obj, "guid", false, "INVALID_GUID"))
                end
            end
            
            if z_data.type == "ScriptingTrigger" or z_data.type == "ScriptingZone" then
                table.insert(zones_data.scripting_zones, z_data)
            elseif z_data.type == "LayoutZone" then
                 table.insert(zones_data.layout_zones, z_data)
            else
                table.insert(zones_data.other_zones, z_data)
            end
        end
    end
    return zones_data
end

local function gather_notebook_info()
    if not state.include_notebook then return {} end 
    local notebook_data = { tabs = {} }
    if not Notes or type(Notes) ~= 'table' then -- API Check for Notes table
        safe_print("gather_notebook_info: Notes API is not available or not a table. Type: " .. type(Notes))
        return notebook_data 
    end

    local tab_indices_array = get_obj_prop(Notes, "getTabs", true, nil)
    if not tab_indices_array or type(tab_indices_array) ~= 'table' then 
        safe_print("gather_notebook_info: Notes.getTabs() failed or returned invalid data. Data: " .. tostring(tab_indices_array))
        return notebook_data 
    end
    safe_print(string.format("gather_notebook_info: Found %d notebook tabs info objects.", #tab_indices_array))

    for _, tab_info_obj in ipairs(tab_indices_array) do 
        if tab_info_obj and type(tab_info_obj) == 'table' and tab_info_obj.index and tab_info_obj.title then
             local content = get_obj_prop(Notes, "getNotes", true, "", tab_info_obj.index)
             table.insert(notebook_data.tabs, {
                 index = tab_info_obj.index,
                 title = tab_info_obj.title,
                 content_length = #content,
                 content_preview = string.sub(content, 1, 200) .. (#content > 200 and "..." or "")
             }) 
        end
    end
    return notebook_data
end

-- 主要上下文收集函数
local function gather_game_context()
    if not state.auto_context then 
        safe_print("自动上下文收集已禁用。")
        return 
    end
    safe_print("收集游戏上下文...")
    
    -- Game name detection is now part of gather_game_info and updates state.current_game_name directly.

    state.game_context = {
        game_info = gather_game_info(), 
        objects = gather_objects_info(),
        players = gather_players_info(),
        zones = gather_zones_info(),
        notebook = gather_notebook_info(),
        last_updated = os.time()
    }
    safe_print("上下文收集完成，游戏: ".. state.current_game_name .. ", 对象: " .. (state.game_context.objects and state.game_context.objects.total_objects or 0))
    if UI and UI.setXml and not state.ui_minimized then -- Avoid refreshing UI if minimized
        local ui_update_success = pcall(create_ui) 
        if not ui_update_success then safe_print("create_ui call failed during context gather") end
    end
end

-- =====================================
-- 🧠 智能提示词生成系统
-- =====================================

-- 生成游戏状态摘要 (Refactored to use new context structure)
local function generate_game_summary()
    local context = state.game_context
    if not context or not context.game_info then return "无游戏状态信息或上下文未初始化" end
    
    local summary_parts = {}
    table.insert(summary_parts, "当前游戏: " .. (context.game_info.game_name or "未知") .. " (模式: " .. (context.game_info.game_mode or "未知") .. ")")
    table.insert(summary_parts, "玩家数量: " .. tostring(context.game_info.player_count or 0) .. " (颜色: " .. (table.concat(context.game_info.seated_players_colors or {}, ", ") or "无") .. ")")
    
    if context.game_info.turn_info then
        local ti = context.game_info.turn_info
        table.insert(summary_parts, "当前回合玩家: " .. (ti.current_player_color or "N/A"))
        if ti.round then table.insert(summary_parts, "回合数: " .. tostring(ti.round)) end
        if ti.phase then table.insert(summary_parts, "阶段: " .. tostring(ti.phase)) end
        if ti.turn_order and #ti.turn_order > 0 then table.insert(summary_parts, "行动顺序: " .. table.concat(ti.turn_order, " -> ")) end
    end

    if context.objects then
        table.insert(summary_parts, "\n[桌面对象统计]")
        table.insert(summary_parts, "  总数: " .. tostring(context.objects.total_objects or 0))
        if context.objects.by_type then
            for obj_type, count in pairs(context.objects.by_type) do
                table.insert(summary_parts, "  - " .. tostring(obj_type) .. ": " .. tostring(count))
            end
        end
        -- Could add more details about specific object categories if needed, e.g., #context.objects.cards
    end

    if context.players and next(context.players) then -- Check if players table is not empty
        table.insert(summary_parts, "\n[玩家状态]")
        for color, p_data in pairs(context.players) do
            local p_summary = "  玩家 " .. tostring(color) .. " (" .. (p_data.steam_name or "匿名") .. "): 手牌区" .. tostring(p_data.hand_zone_info.object_count or 0) .. "张, 手持" .. ((p_data.held_object_info and p_data.held_object_info.guid and "1" or "0")) .. "件, 选中" .. tostring(p_data.selected_objects_count or 0) .. "件"
            if p_data.held_object_info and p_data.held_object_info.guid then
                p_summary = p_summary .. " (持: " .. (p_data.held_object_info.name or "未命名") .. " - " .. (p_data.held_object_info.type or "未知类型") .. ")"
            end
            table.insert(summary_parts, p_summary)
        end
    end

    if context.zones then
        local zone_counts = "脚本区: " .. tostring(#(context.zones.scripting_zones or {})) .. ", 布局区: " .. tostring(#(context.zones.layout_zones or {})) .. ", 其他区: " .. tostring(#(context.zones.other_zones or {}))
        table.insert(summary_parts, "\n[区域信息] " .. zone_counts)
    end

    if context.notebook and context.notebook.tabs and #context.notebook.tabs > 0 then
        table.insert(summary_parts, "\n[笔记] 共 " .. tostring(#context.notebook.tabs) .. " 个标签页")
        for i, tab_data in ipairs(context.notebook.tabs) do
            if i > 3 then -- Limit preview to first 3 tabs to keep summary concise
                table.insert(summary_parts, "  ...等 " .. tostring(#context.notebook.tabs - 3 + 1) .. " 个标签页")
                break
            end
            table.insert(summary_parts, "  标签 " .. tostring(tab_data.index) .. ": \"" .. tostring(tab_data.title) .. "\" (长度: " .. tostring(tab_data.content_length) .. ", 预览: " .. tostring(tab_data.content_preview) .. ")")
        end
    end
        
    return table.concat(summary_parts, "\n")
end

-- 生成基础系统提示词
local function generate_system_prompt()
    return [[你是一个专业的桌游助手，具有以下能力：
1. 规则解释：基于提供的游戏规则文档，准确解释游戏规则
2. 策略建议：根据当前游戏状态，提供合理的策略建议
3. 流程指导：帮助玩家了解游戏流程和回合顺序
4. 问题解答：回答关于游戏机制、计分、胜负条件等问题
请始终：
- 基于提供的游戏状态和规则文档回答
- 如果规则不明确，请说明需要查阅具体规则
- 提供简洁、准确的回答
- 如果涉及策略建议，请提供多个选择方案]]
end

-- 生成完整的LLM查询上下文
local function generate_llm_context(user_question)
    local context_parts = {}
    table.insert(context_parts, "=== 系统角色 ===")
    table.insert(context_parts, generate_system_prompt())
    
    if state.rules_document and state.rules_document ~= "" then
        table.insert(context_parts, "\n=== 游戏规则文档 ===")
        table.insert(context_parts, state.rules_document)
    end
    
    if state.game_context and state.game_context.game_info then
        table.insert(context_parts, "\n=== 当前游戏状态 ===")
        table.insert(context_parts, generate_game_summary())
    else
        table.insert(context_parts, "\n=== 当前游戏状态 ===")
        table.insert(context_parts, "游戏状态信息不可用或未收集。")
    end
    
    table.insert(context_parts, "\n=== 玩家问题 ===")
    table.insert(context_parts, user_question or "未提供问题。")
    
    return table.concat(context_parts, "\n")
end

-- =====================================
-- 📚 规则文档管理系统
-- =====================================

-- 加载规则文档
local function load_rules_document(document_text)
    if not document_text or document_text == "" then
        safe_broadcast("❌ 规则文档为空", {1, 0, 0})
        return false
    end
    state.rules_document = document_text
    safe_broadcast("✅ 规则文档已加载（" .. #document_text .. " 字符）")
    return true
end

-- 清除规则文档
local function clear_rules_document()
    state.rules_document = ""
    safe_broadcast("✅ 规则文档已清除")
end

