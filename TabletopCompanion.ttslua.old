-- =====================================
-- 🔗 LLM连接 (增强版) - 支持Ollama和Gemini
-- =====================================

-- 发送Gemini API请求的辅助函数
local function send_gemini_request(api_key, model_name, prompt_text, player_for_response)
    if not WebRequest or not WebRequest.custom then
        safe_broadcast("❌ WebRequest.custom方法不可用 (Gemini)", {1,0,0}, player_for_response)
        return
    end
    if not JSON or not safe_json_encode or not safe_json_decode then -- 确保JSON工具可用
        safe_broadcast("❌ JSON模块或相关安全函数不可用 (Gemini)", {1,0,0}, player_for_response)
        return
    end
    if not api_key or api_key == "" then
        safe_broadcast("❌ Gemini API Key未配置。请使用 'tc config gemini <API_KEY>' 进行配置。", {1,0,0}, player_for_response)
        return
    end

    local api_url = "https://generativelanguage.googleapis.com/v1beta/models/" .. model_name .. ":generateContent?key=" .. api_key
    
    local request_body = {
        contents = {
            {
                parts = {
                    {text = prompt_text}
                }
            }
        }
        -- 可以根据需要添加 generationConfig 等参数
        -- generationConfig = {
        --    temperature = 0.7,
        --    maxOutputTokens = 1024,
        -- }
    }

    local json_body = safe_json_encode(request_body)
    if not json_body then
        safe_broadcast("❌ 无法编码Gemini请求数据", {1,0,0}, player_for_response)
        return
    end

    safe_print("发送Gemini请求到: " .. model_name .. " (上下文长度: " .. #prompt_text .. ")")

    local headers = { ["Content-Type"] = "application/json" }

    pcall(WebRequest.custom, api_url, "POST", true, json_body, headers, function(request)
        if request.is_error then
            safe_print("Gemini API错误: " .. tostring(request.error))
            safe_print("Gemini原始错误响应: " .. tostring(request.text))
            safe_broadcast("❌ Gemini API请求失败: " .. tostring(request.error), {1,0,0}, player_for_response)
            if request.text then
                local err_data = safe_json_decode(request.text)
                if err_data and err_data.error and err_data.error.message then
                    safe_broadcast("错误详情: " .. err_data.error.message, {1,0.5,0}, player_for_response)
                end
            end
        else
            safe_print("Gemini响应成功, 长度: " .. #request.text)
            local data = safe_json_decode(request.text)
            
            if data and data.candidates and data.candidates[1] and data.candidates[1].content and data.candidates[1].content.parts then
                local full_response_text = ""
                for _, part in ipairs(data.candidates[1].content.parts) do
                    if part.text then
                        full_response_text = full_response_text .. part.text
                    end
                end
                
                if full_response_text ~= "" then
                    state.success_count = (state.success_count or 0) + 1
                    safe_broadcast("🤖 " .. full_response_text, nil, player_for_response)
                else
                    safe_broadcast("❌ Gemini回复中未找到有效文本内容。原始响应见日志。", {1,0.5,0}, player_for_response)
                    safe_print("原始Gemini响应 (解析后无文本): " .. request.text)
                end
            elseif data and data.error then -- 处理API返回的结构化错误
                safe_print("Gemini API返回错误: " .. data.error.message)
                safe_broadcast("❌ Gemini API返回错误: " .. data.error.message, {1,0.5,0}, player_for_response)
            else
                safe_broadcast("❌ 无法解析Gemini回复的结构。原始响应见日志。", {1,0.5,0}, player_for_response)
                safe_print("原始Gemini响应: " .. request.text)
            end
        end
    end)
end

local function test_llm_connection(requesting_player) -- 添加 requesting_player 参数
    if state.llm_provider == "ollama" then
        safe_broadcast("🔍 测试Ollama连接...", nil, requesting_player) -- 定向初始消息
        if not WebRequest or not WebRequest.custom then safe_broadcast("❌ WebRequest不可用", {1,0,0}, requesting_player); return end
        if not JSON then safe_broadcast("❌ JSON模块不可用", {1,0,0}, requesting_player); return end
        
        local request_data = { model = state.ollama_model, prompt = "请简单回复'Ollama测试成功'", stream = false }
        local json_data = safe_json_encode(request_data)
        if not json_data then safe_broadcast("❌ 无法编码Ollama请求数据", {1,0,0}, requesting_player); return end
        
        safe_print("发送Ollama测试请求到: " .. state.ollama_url .. "/api/generate")
        local headers = { ["Content-Type"] = "application/json" }
        
        pcall(WebRequest.custom, state.ollama_url .. "/api/generate", "POST", true, json_data, headers, function(request)
            if request.is_error then
                safe_print("Ollama连接错误: " .. tostring(request.error))
                safe_broadcast("❌ Ollama连接失败: " .. tostring(request.error), {1,0,0}, requesting_player)
            else
                safe_print("Ollama响应状态: 成功, 长度: " .. #request.text)
                local data = safe_json_decode(request.text)
                if data and data.response then
                    safe_broadcast("✅ Ollama测试成功！AI回复: " .. data.response, {0,1,0}, requesting_player)
                else
                    safe_broadcast("❌ Ollama响应解析失败。原始响应见日志。", {1,0.5,0}, requesting_player)
                    safe_print("原始Ollama响应: " .. request.text)
                end
            end
        end)
    elseif state.llm_provider == "gemini" then
        safe_broadcast("🔍 测试Gemini API连接...", nil, requesting_player) -- 定向初始消息
        if not state.gemini_key or state.gemini_key == "" then
             safe_broadcast("❌ Gemini API Key未配置。请使用 'tc config gemini <API_KEY>' 进行配置。", {1,0,0}, requesting_player)
             return
        end
        send_gemini_request(state.gemini_key, state.gemini_model, "请简单回复'Gemini测试成功'，无需任何markdown或其他格式。", requesting_player)
    else
        safe_broadcast("❌ 未配置LLM提供商。请使用 'tc config ollama ...' 或 'tc config gemini ...'。", {1,0,0}, requesting_player)
    end
end

local function query_llm(question, player)
    if not question or question == "" then 
        safe_player_action(player, function(p) p.print("问题不能为空。") end)
        return 
    end
    state.query_count = (state.query_count or 0) + 1
    
    if state.llm_provider == "none" then
        safe_broadcast("❌ 未配置LLM提供商。请使用 'tc config ollama ...' 或 'tc config gemini ...'。", {1,0,0})
        return
    end

    safe_broadcast("🤔 ["..state.llm_provider.."] 正在分析游戏状态并查询: " .. question)

    if state.auto_context then
        local context_success, context_err = pcall(gather_game_context)
        if not context_success then safe_print("gather_game_context失败: " .. tostring(context_err)) end
    end

    local llm_context_success, full_context = pcall(generate_llm_context, question)
    if not llm_context_success then
        safe_print("generate_llm_context失败: " .. tostring(full_context))
        full_context = "基础查询 (上下文生成失败): " .. question
    end
    
    if state.llm_provider == "ollama" then
        if not WebRequest or not WebRequest.custom then safe_broadcast("❌ WebRequest不可用 (Ollama)", {1,0,0}); return end
        if not JSON then safe_broadcast("❌ JSON模块不可用 (Ollama)", {1,0,0}); return end
        
        local request_data = { model = state.ollama_model, prompt = full_context, stream = false }
        local headers = { ["Content-Type"] = "application/json" }
        local json_data = safe_json_encode(request_data)
        if not json_data then safe_broadcast("❌ 无法编码Ollama请求数据", {1,0,0}); return end
        
        safe_print("发送Ollama请求 (上下文长度: " .. #full_context .. ")")
        pcall(WebRequest.custom, state.ollama_url .. "/api/generate", "POST", true, json_data, headers, function(request)
            if request.is_error then
                safe_broadcast("❌ Ollama查询失败: " .. tostring(request.error), {1,0,0})
            else
                local data = safe_json_decode(request.text)
                if data and data.response then
                    state.success_count = (state.success_count or 0) + 1
                    safe_broadcast("🤖 " .. data.response)
                else
                    safe_broadcast("❌ 无法解析Ollama回复。原始响应见日志。", {1,0.5,0})
                    safe_print("原始Ollama响应: " .. request.text)
                end
            end
        end)
    elseif state.llm_provider == "gemini" then
        send_gemini_request(state.gemini_key, state.gemini_model, full_context, player)
    end
end

-- =====================================
-- 🎯 命令处理系统 (函数定义必须在onChat之前)
-- =====================================

-- 解析tc命令
local function parse_tc_command(message)
    local parts = {}
    local current_word = ""
    if type(message) ~= "string" then return parts end
    for i = 1, #message do
        local char = message:sub(i, i)
        if char == " " or char == "\t" then
            if current_word ~= "" then table.insert(parts, current_word); current_word = "" end
        else
            current_word = current_word .. char
        end
    end
    if current_word ~= "" then table.insert(parts, current_word) end
    return parts
end

-- 显示帮助
local function show_help(player)
    local help_text = 
"🎲 桌游伴侣使用指南 v" .. (VERSION or "未知") .. "\n\n"
.. "基础命令:\n"
.. "  tc help         - 显示此帮助\n"
.. "  tc status       - 显示当前状态\n"
.. "  tc test         - 测试当前配置的LLM连接 (" .. (state.llm_provider or "未配置") .. ")\n\n"
.. "配置命令:\n"
.. "  tc config ollama <URL> <模型> - 配置Ollama (例: tc config ollama http://localhost:11434 gemma2:9b)\n"
.. "  tc config gemini <API_KEY> [模型] - 配置Gemini (模型可选, 默认 " .. (state.gemini_model or "gemini-pro") .. ")\n\n"
.. "LLM提供商切换:\n"
.. "  运行任一 'tc config ...' 命令即可切换并使用对应的LLM服务。\n"
.. "  当前LLM提供商: " .. (state.llm_provider or "未配置") .. "\n\n"
.. "上下文命令:\n"
.. "  tc context refresh     - 手动刷新游戏上下文\n"
.. "  tc context auto on/off - 切换自动上下文收集 (当前: " .. (state.auto_context and "开" or "关") .. ")\n"
.. "  tc context show        - 显示当前收集的游戏状态摘要\n"
.. "  tc context objects on/off - 切换是否包含对象信息 (当前: " .. (state.include_objects and "开" or "关") .. ")\n"
.. "  tc context players on/off - 切换是否包含玩家信息 (当前: " .. (state.include_players and "开" or "关") .. ")\n"
.. "  tc context zones on/off   - 切换是否包含区域信息 (当前: " .. (state.include_zones and "开" or "关") .. ")\n"
.. "  tc context notebook on/off - 切换是否包含笔记信息 (当前: " .. (state.include_notebook and "开" or "关") .. ")\n\n"
.. "规则命令:\n"
.. "  tc rules load <粘贴的规则文本> - 加载游戏规则 (直接粘贴文本)\n"
.. "  tc rules clear         - 清除已加载的规则\n"
.. "  tc rules status        - 显示规则文档加载状态\n\n"
.. "查询:\n"
.. "  @tc <你的问题>      - 向当前LLM (" .. (state.llm_provider or "未配置") .. ") 提问 (会自动附加游戏上下文)\n\n"
.. "示例:\n"
.. "  tc config gemini YOUR_API_KEY_HERE\n"
.. "  tc rules load 这是一个策略游戏...\n"
.. "  @tc 我现在应该做什么？"

    if player then
        safe_print(string.format("show_help: Player object received. Color: %s, Type: %s, Has .print: %s", 
            tostring(player.color), -- Ensure player.color is stringified
            type(player), 
            tostring(player.print ~= nil)))
        safe_player_action(player, function(p) 
            if p and p.print then 
                p.print(help_text) 
            else 
                safe_print("show_help/action_func: p or p.print is nil. Cannot print help to player.")
            end 
        end, "显示帮助")
    else
        safe_print("show_help: Player object is nil. Broadcasting help to console/all.")
        safe_broadcast("📖 帮助信息已输出到控制台日志。")
        safe_print("================ 帮助信息 ================\n" .. help_text .. "\n========================================")
    end
end

-- 显示状态
local function show_status(player)
    local status_text = ""
    if state then
        local rules_status = "未加载"
        if state.rules_document and state.rules_document ~= "" then
            rules_status = "已加载 (" .. #state.rules_document .. "字符)"
        end

        local llm_details = "未配置"
        if state.llm_provider == "ollama" then
            llm_details = "Ollama (URL: " .. (state.ollama_url or "未设置") .. ", 模型: " .. (state.ollama_model or "未选择") .. ")"
        elseif state.llm_provider == "gemini" then
            llm_details = "Gemini (模型: " .. (state.gemini_model or "未选择") .. ", API Key: " .. (state.gemini_key and "已设置" or "未设置") .. ")"
        end

        local notebook_status = state.include_notebook and "包含" or "排除"

        status_text = 
"🎲 桌游伴侣状态 v" .. (VERSION or "未知") .. "\n\n"
.. "当前LLM提供商: " .. (state.llm_provider or "未配置") .. "\n"
.. "  " .. llm_details .. "\n\n"
.. "游戏状态:\n"
.. "  当前游戏: " .. (state.current_game_name or "未知") .. "\n"
.. "  规则文档: " .. rules_status .. "\n"
.. "  自动上下文: " .. (state.auto_context and "启用" or "禁用") .. " (对象: " .. (state.include_objects and "包含" or "排除") .. ", 玩家: " .. (state.include_players and "包含" or "排除") .. ", 区域: " .. (state.include_zones and "包含" or "排除") .. ", 笔记: " .. notebook_status .. ")\n\n"
.. "统计:\n"
.. "  总查询次数: " .. tostring(state.query_count or 0) .. "\n"
.. "  成功回复次数: " .. tostring(state.success_count or 0)
    else
        status_text = "错误：state表未初始化。"
    end
    
    if player then
        safe_print(string.format("show_status: Player object received. Color: %s, Type: %s, Has .print: %s", 
            tostring(player.color), -- Ensure player.color is stringified
            type(player), 
            tostring(player.print ~= nil)))
        safe_player_action(player, function(p) 
            if p and p.print then
                p.print(status_text) 
            else
                safe_print("show_status/action_func: p or p.print is nil. Cannot print status to player.")
            end
        end, "显示状态")
    else
        safe_print("show_status: Player object is nil. Broadcasting status to console/all.")
        safe_broadcast("📊 系统状态已输出到控制台日志。")
        safe_print("================ 系统状态 ================\n" .. status_text .. "\n========================================")
    end
end

-- 处理配置命令
local function handle_config_command(parts, player)
    if not parts or #parts < 3 then
        safe_player_action(player, function(p) p.print("用法: tc config <provider> [options...]") end)
        return
    end
    local provider = parts[3]:lower()
    if provider == "ollama" then
        if #parts < 5 then
            safe_player_action(player, function(p) p.print("用法: tc config ollama <URL> <模型>") end)
            return
        end
        state.ollama_url = parts[4]
        state.ollama_model = parts[5]
        state.llm_provider = "ollama"
        safe_broadcast("✅ Ollama已设为LLM提供商: " .. state.ollama_url .. " | " .. state.ollama_model)
    elseif provider == "gemini" then
        if #parts < 4 then
            safe_player_action(player, function(p) p.print("用法: tc config gemini <API_KEY> [模型名称] (模型可选, 默认为 '" .. state.gemini_model .. "')") end)
            return
        end
        state.gemini_key = parts[4]
        if parts[5] and parts[5] ~= "" then 
            state.gemini_model = parts[5]
        else
            state.gemini_model = "gemini-pro" -- 确保如果未提供模型，则使用默认值
        end
        state.llm_provider = "gemini"
        safe_broadcast("✅ Gemini已设为LLM提供商 (模型: %s). API密钥已设置。", state.gemini_model)
    else
        safe_broadcast("❌ 不支持的提供商: " .. provider .. ". 目前支持 'ollama' 和 'gemini'。", nil, player) -- 向触发者广播
    end
    
    safe_print(string.format("handle_config_command: LLM provider set to '%s'. UI minimized: %s. Refreshing UI.", state.llm_provider, tostring(state.ui_minimized)))

    if UI and UI.setXml then
        if not state.ui_minimized then
            local ui_update_success, ui_err = pcall(create_ui) 
            if not ui_update_success then 
                safe_print("handle_config_command: create_ui 调用失败: " .. tostring(ui_err)) 
            end
        else -- UI is minimized
            safe_print("handle_config_command: UI is minimized. Refreshing minimized UI.")
            local min_ui_update_success, min_ui_err = pcall(create_minimized_ui)
            if not min_ui_update_success then
                safe_print("handle_config_command: create_minimized_ui 调用失败: " .. tostring(min_ui_err))
            end
        end
    else
        safe_print("handle_config_command: UI or UI.setXml not available, cannot refresh UI.")
    end
end

-- 处理上下文相关命令
local function handle_context_command(parts, player)
    if not parts or #parts < 3 then
        show_help(player) -- Show full help if subcommand is missing
        return
    end
    local subcommand = parts[3]
    if subcommand == "refresh" then
        pcall(gather_game_context)
        safe_broadcast("✅ 游戏上下文已刷新")
    elseif subcommand == "auto" then
        if parts[4] == "on" then state.auto_context = true
        elseif parts[4] == "off" then state.auto_context = false
        else state.auto_context = not state.auto_context end
        safe_broadcast("✅ 自动上下文收集: " .. (state.auto_context and "已启用" or "已禁用"))
    elseif subcommand == "show" then
        local summary = generate_game_summary()
        safe_player_action(player, function(p) p.print("=== 当前游戏状态 ===\n" .. summary) end)
    elseif subcommand == "objects" then
        if parts[4] == "on" then state.include_objects = true
        elseif parts[4] == "off" then state.include_objects = false
        else state.include_objects = not state.include_objects end
        safe_broadcast("✅ 对象信息收集: " .. (state.include_objects and "已启用" or "已禁用"))
    elseif subcommand == "players" then
        if parts[4] == "on" then state.include_players = true
        elseif parts[4] == "off" then state.include_players = false
        else state.include_players = not state.include_players end
        safe_broadcast("✅ 玩家信息收集: " .. (state.include_players and "已启用" or "已禁用"))
    elseif subcommand == "zones" then
        if parts[4] == "on" then state.include_zones = true
        elseif parts[4] == "off" then state.include_zones = false
        else state.include_zones = not state.include_zones end
        safe_broadcast("✅ 区域信息收集: " .. (state.include_zones and "已启用" or "已禁用"))
    elseif subcommand == "notebook" then
        if parts[4] == "on" then state.include_notebook = true
        elseif parts[4] == "off" then state.include_notebook = false
        else state.include_notebook = not state.include_notebook end
        safe_broadcast("✅ 笔记信息收集: " .. (state.include_notebook and "已启用" or "已禁用"))
    else
        safe_player_action(player, function(p) p.print("❌ 未知上下文子命令: " .. subcommand) end)
    end
    pcall(create_ui) -- Refresh UI as context settings might have changed
end

-- 处理规则相关命令
local function handle_rules_command(parts, player)
    if not parts or #parts < 3 then
        show_help(player)
        return
    end
    local subcommand = parts[3]
    if subcommand == "load" then
        local document_text_parts = {}
        for i = 4, #parts do table.insert(document_text_parts, parts[i]) end
        local document_text = table.concat(document_text_parts, " ")
        
        while #document_text > 0 and (document_text:sub(1,1) == " " or document_text:sub(1,1) == "\t") do
            document_text = document_text:sub(2)
        end
        while #document_text > 0 and (document_text:sub(-1,-1) == " " or document_text:sub(-1,-1) == "\t") do
            document_text = document_text:sub(1,-2)
        end
        if load_rules_document(document_text) then
            pcall(create_ui) -- Refresh UI
        end
    elseif subcommand == "clear" then
        clear_rules_document()
        pcall(create_ui) -- Refresh UI
    elseif subcommand == "status" then
        local rules_status_msg = "规则文档状态: "
        if state.rules_document and state.rules_document ~= "" then
            rules_status_msg = rules_status_msg .. "已加载 (" .. #state.rules_document .. " 字符)"
        else
            rules_status_msg = rules_status_msg .. "未加载"
        end
        safe_player_action(player, function(p) p.print(rules_status_msg) end)
    else
        safe_player_action(player, function(p) p.print("❌ 未知规则子命令: " .. subcommand) end)
    end
end

-- =====================================
-- 🎨 用户界面（增强版）
-- =====================================

local function create_ui()
    if not UI then safe_print("UI模块不可用，跳过UI创建"); return end
    
    safe_print("create_ui: Current LLM provider from state: " .. (state.llm_provider or "nil/未配置"))

    local game_name_display = state.current_game_name or "未知"
    if game_name_display == "" then game_name_display = "未知" end

    local rules_doc_status = "未加载"
    if state.rules_document and state.rules_document ~= "" then
        rules_doc_status = "已加载 (" .. #state.rules_document .. "字)"
    end
    
    local obj_count_display = "N/A"
    if state.game_context and state.game_context.objects and state.game_context.objects.total_objects ~= nil then
        obj_count_display = tostring(state.game_context.objects.total_objects)
    end
    local player_count_display = "N/A"
    if state.game_context and state.game_context.game_info and state.game_context.game_info.player_count ~= nil then
        player_count_display = tostring(state.game_context.game_info.player_count)
    end

    local llm_status_ui = "未配置"
    if state.llm_provider == "ollama" then
        llm_status_ui = "Ollama"
    elseif state.llm_provider == "gemini" then
        llm_status_ui = "Gemini"
    end

    local notebook_tab_count_display = "N/A"
    if state.game_context and state.game_context.notebook and state.game_context.notebook.tabs then
        notebook_tab_count_display = tostring(#state.game_context.notebook.tabs)
    end

    local panel_id_main = "MainPanel"
    local stored_offset_main = state.ui_panel_offsets and state.ui_panel_offsets.main or "80 -10"
    local final_offset_main = stored_offset_main

    if UI.getAttribute then
        local success_get_main, actual_offset_main = pcall(UI.getAttribute, panel_id_main, "offsetXY")
        if success_get_main and actual_offset_main and type(actual_offset_main) == "string" and actual_offset_main ~= "" then
            final_offset_main = actual_offset_main
            if state.ui_panel_offsets then state.ui_panel_offsets.main = actual_offset_main end
        end
    end

    local ui_xml = 
'<Panel غورهAlignment="UpperLeft" offsetXY="' .. final_offset_main .. '" width="350" height="160" id="MainPanel" allowDragging="true" returnToOriginalPositionWhenReleased="false">\n'
..'    <Panel color="#2D1B69E6" width="100%%" height="100%%" outline="#4C3A7B" outlineSize="2">\n'
..'        <Text fontSize="16" color="#FFD700" alignment="MiddleCenter" offsetXY="0 65" fontStyle="Bold">\n'
..'            🎲 桌游伴侣 v' .. (VERSION or "N/A") .. '\n'
..'        </Text>\n'
..'        <Text fontSize="10" color="#E6E6FA" alignment="MiddleCenter" offsetXY="0 50">\n'
..'            智能游戏助手 - 上下文感知AI\n'
..'        </Text>\n'
..'        <Text fontSize="9" color="#B0C4DE" alignment="MiddleCenter" offsetXY="0 36">\n'
..'            游戏: ' .. game_name_display .. ' | 规则: ' .. rules_doc_status .. '\n'
..'        </Text>\n'
..'        <Text fontSize="8" color="#98FB98" alignment="MiddleCenter" offsetXY="0 24">\n'
..'            对象: ' .. obj_count_display .. ' | 玩家: ' .. player_count_display .. ' | LLM: ' .. llm_status_ui .. ' | 笔记页: ' .. notebook_tab_count_display .. '\n'
..'        </Text>\n'
..'        <Panel offsetXY="0 0" width="330" height="28" color="#3E2A8A80">\n'
..'            <Button onClick="ui_show_help" width="70" height="22" offsetXY="-120 0" color="#6A5ACD" highlightColor="#7B68EE" tooltip="显示帮助信息">\n'
..'                <Text fontSize="9" color="#FFFFFF" alignment="MiddleCenter">帮助</Text>\n'
..'            </Button>\n'
..'            <Button onClick="ui_show_status" width="70" height="22" offsetXY="-40 0" color="#6A5ACD" highlightColor="#7B68EE" tooltip="显示系统状态">\n'
..'                <Text fontSize="9" color="#FFFFFF" alignment="MiddleCenter">状态</Text>\n'
..'            </Button>\n'
..'            <Button onClick="ui_refresh_context" width="70" height="22" offsetXY="40 0" color="#228B22" highlightColor="#32CD32" tooltip="刷新游戏上下文">\n'
..'                <Text fontSize="9" color="#FFFFFF" alignment="MiddleCenter">刷新上下文</Text>\n'
..'            </Button>\n'
..'            <Button onClick="ui_minimize" width="70" height="22" offsetXY="120 0" color="#FF6347" highlightColor="#FF7F50" tooltip="最小化面板">\n'
..'                <Text fontSize="9" color="#FFFFFF" alignment="MiddleCenter">最小化</Text>\n'
..'            </Button>\n'
..'        </Panel>\n'
..'        <Panel offsetXY="0 -30" width="330" height="28" color="#3E2A8A80">\n'
..'            <Button onClick="ui_toggle_auto_context" width="100" height="22" offsetXY="-105 0" color="#4682B4" highlightColor="#5F9EA0" tooltip="切换自动上下文收集">\n'
..'                <Text fontSize="8" color="#FFFFFF" alignment="MiddleCenter">自动上下文: ' .. (state.auto_context and "开" or "关") .. '</Text>\n'
..'            </Button>\n'
..'            <Button onClick="ui_clear_rules" width="100" height="22" offsetXY="0 0" color="#DC143C" highlightColor="#F08080" tooltip="清除已加载的规则文档">\n'
..'                <Text fontSize="8" color="#FFFFFF" alignment="MiddleCenter">清除规则</Text>\n'
..'            </Button>\n'
..'            <Button onClick="ui_test_connection" width="100" height="22" offsetXY="105 0" color="#FF8C00" highlightColor="#FFA500" tooltip="测试当前LLM连接">\n'
..'                <Text fontSize="8" color="#FFFFFF" alignment="MiddleCenter">测试连接</Text>\n'
..'            </Button>\n'
..'        </Panel>\n'
..'    </Panel>\n'
..'</Panel>'
    
    local success, err = pcall(UI.setXml, ui_xml)
    if not success then 
        safe_print("UI创建失败: " .. tostring(err))
    else
        safe_print(string.format("UI.setXml successful for %s.", panel_id_main))
        safe_print(string.format("Attempting to register offsetXY callback for %s. UI.setAttributeChanged type: %s", panel_id_main, type(UI.setAttributeChanged)))
        if UI.setAttributeChanged and type(UI.setAttributeChanged) == 'function' then
            safe_print("UI.setAttributeChanged function exists and is a function.")
            if _G["ui_panel_offset_changed"] and type(_G["ui_panel_offset_changed"]) == 'function' then
                safe_print("Callback function ui_panel_offset_changed exists globally and is a function.")
                local reg_succ, reg_err = pcall(UI.setAttributeChanged, panel_id_main, "offsetXY", "ui_panel_offset_changed")
                if not reg_succ then
                    safe_print(string.format("pcall to UI.setAttributeChanged for %s failed: %s", panel_id_main, tostring(reg_err)))
                else
                    safe_print(string.format("UI.setAttributeChanged registration for %s completed. Success status from TTS: %s", panel_id_main, tostring(reg_err)))
                end
            else
                safe_print(string.format("Callback function ui_panel_offset_changed NOT FOUND globally or not a function (type: %s).", type(_G["ui_panel_offset_changed"])))
            end
        else
            safe_print(string.format("UI.setAttributeChanged function is NOT available or not a function for panel %s (type: %s). Skipping registration.", panel_id_main, type(UI.setAttributeChanged)))
        end
    end
end

local function create_minimized_ui()
    if not UI then safe_print("UI模块不可用，跳过最小化UI创建"); return end

    safe_print("create_minimized_ui: Current LLM provider from state: " .. (state.llm_provider or "nil/未配置"))

    local panel_id_minimized = "MinimizedPanel"
    local stored_offset_minimized = state.ui_panel_offsets and state.ui_panel_offsets.minimized or "80 -10"
    local final_offset_minimized = stored_offset_minimized

    if UI.getAttribute then
        local success_get_minimized, actual_offset_minimized = pcall(UI.getAttribute, panel_id_minimized, "offsetXY")
        if success_get_minimized and actual_offset_minimized and type(actual_offset_minimized) == "string" and actual_offset_minimized ~= "" then
            final_offset_minimized = actual_offset_minimized
            if state.ui_panel_offsets then state.ui_panel_offsets.minimized = actual_offset_minimized end
        end
    end

    local ui_xml = 
'<Panel rectAlignment="UpperLeft" offsetXY="' .. final_offset_minimized .. '" width="200" height="35" id="MinimizedPanel" allowDragging="true" returnToOriginalPositionWhenReleased="false">\n'
..'    <Panel color="#2D1B69E6" width="100%%" height="100%%" outline="#4C3A7B" outlineSize="2">\n'
..'        <Button onClick="ui_restore" width="190" height="28" color="#6A5ACD" highlightColor="#7B68EE" tooltip="还原完整面板">\n'
..'            <Text fontSize="12" color="#FFD700" alignment="MiddleCenter" fontStyle="Bold">🎲 桌游伴侣 v' .. (VERSION or "N/A") .. ' ✨</Text>\n'
..'        </Button>\n'
..'    </Panel>\n'
..'</Panel>'
    local success, err = pcall(UI.setXml, ui_xml)
    if not success then 
        safe_print("最小化UI创建失败: " .. tostring(err))
    else
        safe_print(string.format("UI.setXml successful for %s.", panel_id_minimized))
        safe_print(string.format("Attempting to register offsetXY callback for %s. UI.setAttributeChanged type: %s", panel_id_minimized, type(UI.setAttributeChanged)))
        if UI.setAttributeChanged and type(UI.setAttributeChanged) == 'function' then
            safe_print("UI.setAttributeChanged function exists and is a function for minimized UI.")
            if _G["ui_panel_offset_changed"] and type(_G["ui_panel_offset_changed"]) == 'function' then
                safe_print("Callback function ui_panel_offset_changed exists globally and is a function for minimized UI.")
                local reg_succ, reg_err = pcall(UI.setAttributeChanged, panel_id_minimized, "offsetXY", "ui_panel_offset_changed")
                if not reg_succ then
                    safe_print(string.format("pcall to UI.setAttributeChanged for %s failed: %s", panel_id_minimized, tostring(reg_err)))
                else
                    safe_print(string.format("UI.setAttributeChanged registration for %s completed. Success status from TTS: %s", panel_id_minimized, tostring(reg_err)))
                end
            else
                safe_print(string.format("Callback function ui_panel_offset_changed NOT FOUND globally or not a function for minimized UI (type: %s).", type(_G["ui_panel_offset_changed"])))
            end
        else
            safe_print(string.format("UI.setAttributeChanged function is NOT available or not a function for panel %s (type: %s). Skipping registration.", panel_id_minimized, type(UI.setAttributeChanged)))
        end
    end
end

-- UI事件处理（增强版）
function ui_show_help(player_who_clicked, value, id) -- 添加 player_who_clicked
    safe_print("ui_show_help called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    if type(show_help) == "function" then
        show_help(player_who_clicked) -- 传递 player_who_clicked
    else
        safe_print("错误: show_help 不是函数! (UI)")
    end
end

function ui_show_status(player_who_clicked, value, id) -- 添加 player_who_clicked
    safe_print("ui_show_status called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    if type(show_status) == "function" then
        show_status(player_who_clicked) -- 传递 player_who_clicked
    else
        safe_print("错误: show_status 不是函数! (UI)")
    end
end

function ui_refresh_context(player_who_clicked, value, id) -- 添加 player_who_clicked
    safe_print("ui_refresh_context called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    pcall(gather_game_context)
    safe_broadcast("✅ 游戏上下文已刷新", nil, player_who_clicked) -- 尝试定向广播
    pcall(create_ui)
end

function ui_toggle_auto_context(player_who_clicked, value, id) -- 添加 player_who_clicked
    safe_print("ui_toggle_auto_context called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    state.auto_context = not state.auto_context
    safe_broadcast("✅ 自动上下文收集: " .. (state.auto_context and "已启用" or "已禁用"), nil, player_who_clicked)
    pcall(create_ui)
end

function ui_clear_rules(player_who_clicked, value, id) -- 添加 player_who_clicked
    safe_print("ui_clear_rules called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    clear_rules_document() -- clear_rules_document 内部调用 safe_broadcast (它需要更新以可能使用player_who_clicked)
    pcall(create_ui)
end

function ui_test_connection(player_who_clicked, value, id) -- 添加 player_who_clicked
    safe_print("ui_test_connection called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    if type(test_llm_connection) == "function" then
        -- test_llm_connection 内部处理广播。如果它需要 player 对象来定向响应，
        -- 那么 test_llm_connection 的签名和逻辑也需要修改以接受和使用 player_who_clicked。
        -- 当前 test_llm_connection 不接受 player 参数，所以响应总是全局的。
        test_llm_connection(effective_player) 
    else
        safe_print("错误: test_llm_connection 不是函数! (UI)")
        safe_broadcast("❌ 内部错误: LLM测试功能异常。", {1,0,0}, player_who_clicked)
    end
end

function ui_minimize(player_who_clicked, value, id) -- player_who_clicked可能为nil
    safe_print("ui_minimize called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    state.ui_minimized = true
    pcall(create_minimized_ui)
end

-- 新的回调函数，用于处理面板offsetXY属性变化 -- (Moved this function higher in the file, before ui_restore)
-- function ui_panel_offset_changed(player_color, panel_id, new_offset_xy) ... end

function ui_restore(player_who_clicked, value, id) -- player_who_clicked可能为nil
    safe_print("ui_restore called by: " .. (player_who_clicked and player_who_clicked.color or "System/Unknown"))
    -- 不再需要在这里尝试获取 MinimizedPanel 的 offsetXY，
    -- 因为 ui_panel_offset_changed 应该已经更新了 state.ui_panel_offsets.minimized
    state.ui_minimized = false
    pcall(create_ui)
end

-- 新的回调函数，用于处理面板offsetXY属性变化
function ui_panel_offset_changed(player_color, panel_id, new_offset_xy)
    safe_print(string.format("[CALLBACK] ui_panel_offset_changed CALLED. Player: %s, Panel ID: %s, New Offset: %s", tostring(player_color), tostring(panel_id), tostring(new_offset_xy)))
    if not panel_id or not new_offset_xy or type(new_offset_xy) ~= "string" or new_offset_xy == "" then
        safe_print(string.format("ui_panel_offset_changed: Invalid arguments (panel_id: %s, offset: %s)", tostring(panel_id), tostring(new_offset_xy)))
        return
    end

    if panel_id == "MainPanel" then
        if state.ui_panel_offsets then state.ui_panel_offsets.main = new_offset_xy end
        safe_print("MainPanel offset changed by user (drag): " .. new_offset_xy)
    elseif panel_id == "MinimizedPanel" then
        if state.ui_panel_offsets then state.ui_panel_offsets.minimized = new_offset_xy end
        safe_print("MinimizedPanel offset changed by user (drag): " .. new_offset_xy)
    else
        safe_print("ui_panel_offset_changed: Unknown panel_id: " .. panel_id)
    end
end

-- =====================================
-- 🚀 初始化系统（增强版）
-- =====================================

function onLoad(saved_state_json)
    safe_print("桌游伴侣初始化开始...")
    if saved_state_json and saved_state_json ~= "" then
        local decoded_success, data = pcall(safe_json_decode, saved_state_json)
        if decoded_success and data then
            state.llm_provider = data.llm_provider or "none"
            state.ollama_url = data.ollama_url or "http://localhost:11434"
            state.ollama_model = data.ollama_model or "gemma3:12b"
            state.gemini_key = data.gemini_key or nil 
            state.gemini_model = data.gemini_model or "gemini-pro" 
            state.query_count = data.query_count or 0
            state.success_count = data.success_count or 0
            
            local loaded_game_name = data.current_game_name or "未知游戏"
            safe_print(string.format("onLoad: Loaded current_game_name from save: '%s'", tostring(loaded_game_name)))
            if loaded_game_name == "未知游?" then
                safe_print("onLoad: Correcting '未知游?' from saved state to '未知游戏'")
                state.current_game_name = "未知游戏"
            else
                state.current_game_name = loaded_game_name
            end
            
            state.rules_document = data.rules_document or ""
            state.auto_context = data.auto_context == nil and true or data.auto_context 
            state.include_objects = data.include_objects == nil and true or data.include_objects
            state.include_players = data.include_players == nil and true or data.include_players
            state.include_zones = data.include_zones == nil and true or data.include_zones
            state.include_notebook = data.include_notebook == nil and true or data.include_notebook
            state.ui_minimized = data.ui_minimized == nil and false or data.ui_minimized
            state.ui_panel_offsets = data.ui_panel_offsets or { main = "80 -10", minimized = "80 -10" }
            safe_print("配置已恢复")
        else
            safe_print("无法恢复保存的状态: " .. tostring(data)) 
        end
    else
      -- Initialize new settings if no saved state
      state.current_game_name = "未知游戏"
      state.include_notebook = true 
      state.ui_minimized = false
      state.ui_panel_offsets = { main = "80 -10", minimized = "80 -10" }
    end
    
    if state.auto_context then
        local context_success_onLoad, context_err_onLoad = pcall(gather_game_context)
        if not context_success_onLoad then safe_print("初始上下文收集失败 (onLoad): " .. tostring(context_err_onLoad)) end
        else
        if type(detect_game_name) == 'function' then 
            local dn_succ, dn_val = pcall(detect_game_name) 
            if dn_succ and dn_val and dn_val ~= "" then state.current_game_name = dn_val 
            elseif not dn_succ then safe_print("onLoad detect_game_name error: "..tostring(dn_val)) end
        end
    end
    
    if not state.ui_minimized and UI and UI.setXml then 
        local ui_success, ui_err = pcall(create_ui)
        if not ui_success then safe_print("UI创建失败 (onLoad): "..tostring(ui_err)) end
    elseif state.ui_minimized and UI and UI.setXml then 
        local min_ui_succ, min_ui_err = pcall(create_minimized_ui)
        if not min_ui_succ then safe_print("Minimized UI creation failed (onLoad): "..tostring(min_ui_err)) end
    end
    
    -- REMOVING CONTEXT MENU FUNCTIONALITY
    safe_print("右键菜单功能已在此版本中禁用 (onLoad)。")
    -- if addContextMenuItem and type(addContextMenuItem) == 'function' then 
    --     safe_print(string.format("setup_context_menus: Checking addContextMenuItem. Type: %s", type(addContextMenuItem)))
    --     local cmenu_succ, cmenu_err = pcall(setup_context_menus)
    --     if not cmenu_succ then safe_print("右键菜单设置失败 (onLoad): "..tostring(cmenu_err)) end
    -- else 
    --     safe_print(string.format("addContextMenuItem 函数不可用或类型不正确 (type: %s)，跳过右键菜单设置 (onLoad)。", type(addContextMenuItem)))
    -- end
    
    state.ready = true
    safe_print("桌游伴侣初始化完成 v" .. VERSION)
    safe_broadcast("✅ 桌游伴侣已启动 v" .. VERSION .. " - 输入 'tc help' 查看帮助。")
end

function onSave()
    local save_data = {
        llm_provider = state.llm_provider, ollama_url = state.ollama_url,
        ollama_model = state.ollama_model, query_count = state.query_count,
        success_count = state.success_count, current_game_name = state.current_game_name,
        rules_document = state.rules_document, auto_context = state.auto_context,
        include_objects = state.include_objects, include_players = state.include_players,
        include_zones = state.include_zones, include_notebook = state.include_notebook,
        gemini_key = state.gemini_key, gemini_model = state.gemini_model,
        ui_minimized = state.ui_minimized,
        ui_panel_offsets = state.ui_panel_offsets
    }
    local json_data = safe_json_encode(save_data)
    if json_data and json_data ~= "JSON_NOT_AVAILABLE" then
        return json_data
    else
        safe_print("无法保存状态：JSON编码失败或模块不可用")
        return "" -- Return empty string if saving fails
    end
end

-- =====================================
-- 🎯 高级功能与事件监听
-- =====================================

function onObjectDrop(player_color, dropped_object)
    if state.auto_context and state.ready then
        safe_print("检测到对象移动，计划刷新上下文...")
        if Wait and Wait.time then
            local delay_success = pcall(Wait.time, function()
                safe_print("延迟刷新上下文 (onObjectDrop)")
                local context_success = pcall(gather_game_context)
                if context_success then if not state.ui_minimized then pcall(create_ui) end
                else safe_print("上下文刷新失败 (onObjectDrop)") end
            end, 0.5)
            if not delay_success then pcall(gather_game_context) end -- Fallback
        else
            pcall(gather_game_context) -- Fallback if Wait not available
        end
    end
end

function onPlayerChangeColor(player_color)
    if state.auto_context and state.ready then
        safe_print("检测到玩家颜色变化，计划刷新上下文...")
        if Wait and type(Wait.time) == 'function' then -- Check if Wait.time is a function
            local delay_success = pcall(Wait.time, function()
                safe_print("延迟刷新上下文 (onPlayerChangeColor)")
                local context_success = pcall(gather_game_context)
                if context_success then if not state.ui_minimized then pcall(create_ui) end
                else safe_print("上下文刷新失败 (onPlayerChangeColor)") end
            end, 1.0)
            if not delay_success then pcall(gather_game_context) end
        else
            pcall(gather_game_context)
        end
    end
end

