-- =====================================
-- 💬 聊天消息处理（增强版）
-- =====================================

function onChat(message, player_object_raw) -- Renamed parameter to player_object_raw
    safe_print("[onChat START] Raw Message: '" .. tostring(message) .. "' (type: " .. type(message) .. "), Raw PlayerParam: " .. tostring(player_object_raw) .. " (type: " .. type(player_object_raw) .. ")")
    if not state.ready then 
        safe_print("[onChat] State not ready. Aborting.")
        return true 
    end
    if not message or message == "" then 
        safe_print("[onChat] Empty message. Aborting.")
        return true 
    end
    
    local actual_player_object = nil
    local source_player_color_str = "System/Unknown"

    if player_object_raw and type(player_object_raw) == 'userdata' then
        -- Assume player_object_raw is the actual player object
        actual_player_object = player_object_raw
        if actual_player_object.color and type(actual_player_object.color) == 'string' then
            source_player_color_str = actual_player_object.color
        else
            safe_print("[onChat] Received player_object (userdata) but .color property is missing or not a string (type: " .. type(actual_player_object.color) .. "). Using default color string.")
            source_player_color_str = "Player_" .. tostring(player_object_raw) -- Fallback color string
        end
        safe_print("[onChat] actual_player_object IS the raw parameter. Deduced Color Str: '" .. source_player_color_str .. "'. Has .print: " .. tostring(actual_player_object and actual_player_object.print ~= nil))
    else
        safe_print(string.format("[onChat] Raw player parameter is not a direct userdata player object (type: %s). Will use fallback.", type(player_object_raw)))
    end

    local effective_player = actual_player_object
    if not effective_player or not effective_player.print then -- Also check .print for the direct object
        if effective_player and not effective_player.print then
            safe_print("[onChat] actual_player_object (from raw param) lacks .print method. Using fallback.")
        elseif not effective_player then
             safe_print("[onChat] actual_player_object is nil (raw param was not a valid player object). Using fallback.")
        end
        
        effective_player = { 
            print = function(msg_to_print) safe_print("[FallbackPlayer (color: " .. source_player_color_str .. ")]: " .. tostring(msg_to_print)) end,
            color = source_player_color_str 
        }
        safe_print("[onChat] Fallback player created. Color: " .. effective_player.color)
    else
        safe_print("[onChat] Using actual player object from raw parameter. Color: " .. tostring(effective_player.color) .. ", Has .print: " .. tostring(effective_player.print ~= nil))
    end
    safe_print("[onChat END effective_player setup] Color: " .. tostring(effective_player.color) .. ", Has .print: " .. tostring(effective_player.print ~= nil))

    local command_success, result = pcall(function()
        if starts_with(message, "tc ") then
            local parts = parse_tc_command(message)
            if parts[1] == "tc" then
                if parts[2] == "help" then
                    show_help(effective_player)
                elseif parts[2] == "status" then
                    show_status(effective_player)
                elseif parts[2] == "test" then
                    test_llm_connection(effective_player)
                elseif parts[2] == "config" then
                    handle_config_command(parts, effective_player)
                elseif parts[2] == "context" then
                    handle_context_command(parts, effective_player)
                elseif parts[2] == "rules" then
                    handle_rules_command(parts, effective_player)
                elseif parts[2] == "query" then
                    query_llm(parts[3], effective_player)
                else
                    safe_player_action(effective_player, function(p) p.print("❌ 未知命令: " .. parts[2]) end)
                end
            end
        end
    end)

    if not command_success then
        safe_print("onChat: Error processing command: " .. tostring(result))
        safe_player_action(effective_player, function(p) p.print("❌ 命令处理失败: " .. tostring(result)) end)
    end

    return true
end 