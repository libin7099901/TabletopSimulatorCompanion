--[[
    桌游伴侣 (Tabletop Companion) - TTS Mod主入口文件
    版本: 1.0.0
    作者: LeadDeveloperAI (达里奥)
    创建时间: 2025-01-27
    
    描述: 
    - 智能规则查询、自动化计分和游戏流程引导的TTS辅助Mod
    - 基于模块化架构，支持插件式扩展
    - 集成LLM服务提供智能问答和翻译功能
--]]

-- 模块化加载系统
local TabletopCompanion = {}

-- 全局状态
TabletopCompanion.VERSION = "1.0.0"
TabletopCompanion.MOD_NAME = "桌游伴侣"
TabletopCompanion.initialized = false

-- 核心模块依赖表
local core_modules = {
    "core/logger",
    "core/error_handler", 
    "core/module_base",
    "core/main_controller",
    "ui/ui_manager"
}

-- 模块加载器
function TabletopCompanion.loadModule(module_path)
    local success, module = pcall(function()
        -- 在TTS环境中，我们需要直接require模块文件
        -- 这里假设模块文件已经通过#include方式包含在主脚本中
        
        if module_path == "core/logger" then
            return require("src/core/logger")
        elseif module_path == "core/error_handler" then
            return require("src/core/error_handler") 
        elseif module_path == "core/module_base" then
            return require("src/core/module_base")
        elseif module_path == "core/main_controller" then
            return require("src/core/main_controller")
        elseif module_path == "ui/ui_manager" then
            return require("src/ui/ui_manager")
        else
            -- 对于未知模块，返回空模块
            print("警告: 未知模块 " .. module_path .. "，使用空实现")
            return {}
        end
    end)
    
    if not success then
        print("错误: 无法加载模块 " .. module_path .. " - " .. tostring(module))
        return nil
    end
    
    return module
end

-- 系统初始化
function onLoad(saved_data)
    print("=" .. string.rep("=", 50) .. "=")
    print("桌游伴侣 (Tabletop Companion) v" .. TabletopCompanion.VERSION)
    print("初始化开始...")
    print("=" .. string.rep("=", 50) .. "=")
    
    -- 初始化核心模块
    local success, error_msg = pcall(function()
        -- 加载核心模块
        for _, module_path in ipairs(core_modules) do
            local module = TabletopCompanion.loadModule(module_path)
            if not module then
                error("关键模块加载失败: " .. module_path)
            end
        end
        
        -- 确保所有核心模块已加载
        if not Logger then
            Logger = TabletopCompanion.loadModule("core/logger")
        end
        
        if not ErrorHandler then
            ErrorHandler = TabletopCompanion.loadModule("core/error_handler")
        end
        
        if not ModuleBase then
            ModuleBase = TabletopCompanion.loadModule("core/module_base")
        end
        
        if not MainController then
            MainController = TabletopCompanion.loadModule("core/main_controller")
        end
        
        if not UIManager then
            UIManager = TabletopCompanion.loadModule("ui/ui_manager")
        end
        
        -- 注册UI管理器模块到主控制器
        if MainController and UIManager then
            MainController:registerModule("UIManager", UIManager)
        end
        
        -- 初始化主控制器
        if MainController then
            MainController:initialize(saved_data)
        else
            error("主控制器加载失败")
        end
        
        TabletopCompanion.initialized = true
        print("✅ 桌游伴侣初始化成功!")
    end)
    
    if not success then
        print("❌ 桌游伴侣初始化失败: " .. tostring(error_msg))
        TabletopCompanion.initialized = false
        
        -- 显示错误提示UI
        TabletopCompanion.showErrorUI(error_msg)
    end
end

-- 数据保存回调
function onSave()
    if TabletopCompanion.initialized and MainController then
        local save_data = MainController:getSaveData()
        print("📁 桌游伴侣数据已保存")
        return JSON.encode(save_data)
    end
    return ""
end

-- 系统关闭
function onDestroy()
    if TabletopCompanion.initialized and MainController then
        MainController:shutdown()
        print("👋 桌游伴侣已安全关闭")
    end
end

-- 错误UI显示
function TabletopCompanion.showErrorUI(error_message)
    -- 创建简单的错误显示UI
    local ui_xml = [[
<Defaults>
    <Panel class="ErrorPanel" width="400" height="200" offsetXY="0 0"/>
</Defaults>
<Panel class="ErrorPanel" id="TabletopCompanionError">
    <Text fontSize="16" color="#FF0000">桌游伴侣加载失败</Text>
    <Text fontSize="12" color="#FFFFFF">]] .. (error_message or "未知错误") .. [[</Text>
    <Button onClick="TabletopCompanion.closeErrorUI">关闭</Button>
</Panel>
]]
    
    UI.setXml(ui_xml)
end

-- 关闭错误UI
function TabletopCompanion.closeErrorUI()
    UI.setXml("")
end

-- 全局聊天命令处理
function onChat(message, player)
    if not TabletopCompanion.initialized then
        return true
    end
    
    -- 检查是否是桌游伴侣命令
    if string.sub(message, 1, 1) == "/" then
        local command = string.match(message, "^/(%w+)")
        
        if command == "tc" or command == "companion" then
            if MainController and MainController.handleChatCommand then
                MainController:handleChatCommand(message, player)
                return false -- 阻止消息显示在聊天中
            end
        end
    end
    
    return true -- 让其他消息正常显示
end

-- 对象交互回调
function onObjectDrop(player_color, dropped_object)
    if TabletopCompanion.initialized and MainController and MainController.handleObjectDrop then
        MainController:handleObjectDrop(player_color, dropped_object)
    end
end

-- 玩家加入回调  
function onPlayerConnect(player)
    if TabletopCompanion.initialized and MainController and MainController.handlePlayerConnect then
        MainController:handlePlayerConnect(player)
    end
end

-- 调试信息输出
function TabletopCompanion.getDebugInfo()
    local info = {
        version = TabletopCompanion.VERSION,
        initialized = TabletopCompanion.initialized,
        modules_loaded = {},
        memory_usage = "N/A" -- TTS Lua环境下难以准确获取
    }
    
    if MainController then
        info.system_state = MainController.system_state
        info.registered_modules = {}
        for name, _ in pairs(MainController.modules or {}) do
            table.insert(info.registered_modules, name)
        end
    end
    
    return info
end

-- 导出模块供其他脚本使用
return TabletopCompanion 